@{
    ViewData["Title"] = "Plataforma de Monitoreo GPS";
}

<div class="hero-section">
    <div class="hero-content">
        <span class="hero-badge"><i class="fa-solid fa-microchip"></i> Inteligencia & Geocalizacion</span>
        <h1 class="hero-title">Monitoreo Inteligente de Rutas en Tiempo Real</h1>
        <p class="hero-description">
            Plataforma digital avanzada para el control de combis, custers y buses urbanos.
            Optimice la velocidad, detecte desvios instantaneos, reduzca la informalidad y garantice
            la seguridad del pasajero con tecnologia GPS y telemetria de vanguardia.
        </p>
        <div class="hero-actions">
            <a asp-controller="Passenger" asp-action="Index" class="btn-primary" style="font-size: 1.1rem; padding: 0.8rem 2rem;">
                <i class="fa-solid fa-magnifying-glass-location"></i> Consultar Rutas
            </a>
            <a asp-controller="Passenger" asp-action="Register" class="btn-primary" style="font-size: 1.1rem; padding: 0.8rem 2rem; background: var(--secondary);">
                <i class="fa-solid fa-user-plus"></i> Registro de Pasajero
            </a>
            <a asp-controller="Home" asp-action="Login" class="nav-links" style="color: var(--primary); font-weight: 600; text-decoration: underline;">
                Ingresar <i class="fa-solid fa-arrow-right-to-bracket"></i>
            </a>
        </div>
    </div>
    <div class="hero-image-container">
        <img class="hero-image" src="https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?q=80&w=600&auto=format&fit=crop" alt="Dashboard SIMCRUL" />
    </div>
</div>

<div class="kpi-grid" style="max-width: 1400px; margin: 2rem auto; padding: 0 2rem;">
    <div class="glass-card kpi-card" style="padding: 2rem;">
        <i class="fa-solid fa-bolt" style="font-size: 2rem; color: var(--primary); margin-bottom: 1rem;"></i>
        <h3 style="margin-bottom: 0.5rem;">Calculo de Desvios</h3>
        <p style="color: var(--text-secondary); font-size: 0.9rem;">Geofencing dinamico contra polilineas de ruta oficiales en segundos.</p>
    </div>
    <div class="glass-card kpi-card" style="padding: 2rem;">
        <i class="fa-solid fa-gauge" style="font-size: 2rem; color: var(--warning); margin-bottom: 1rem;"></i>
        <h3 style="margin-bottom: 0.5rem;">Control de Velocidad</h3>
        <p style="color: var(--text-secondary); font-size: 0.9rem;">Alertas instantaneas cuando se superan los limites configurados por tramo.</p>
    </div>
    <div class="glass-card kpi-card" style="padding: 2rem;">
        <i class="fa-solid fa-chart-line" style="font-size: 2rem; color: var(--success); margin-bottom: 1rem;"></i>
        <h3 style="margin-bottom: 0.5rem;">Score de Conduccion</h3>
        <p style="color: var(--text-secondary); font-size: 0.9rem;">Algoritmo de puntos ponderados para calificar el desempeno del conductor.</p>
    </div>
    <div class="glass-card kpi-card" style="padding: 2rem;">
        <i class="fa-solid fa-file-invoice-dollar" style="font-size: 2rem; color: var(--secondary); margin-bottom: 1rem;"></i>
        <h3 style="margin-bottom: 0.5rem;">Reportes Profesionales</h3>
        <p style="color: var(--text-secondary); font-size: 0.9rem;">Descarga de reportes ejecutivos en PDF (QuestPDF) y hojas de calculo en Excel (ClosedXML).</p>
    </div>
</div>
