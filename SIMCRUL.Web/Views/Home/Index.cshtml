@{
    ViewData["Title"] = "Bienvenido";
    ViewData["HideChrome"] = true;
}

<section class="auth-wrap">
    <div class="auth-card panel">
        <div class="auth-side">
            <span class="chip">SIMCRUL 2026</span>
            <h2>Gestion integral del mantenimiento de flota</h2>
            <p>Controla inspecciones diarias, incidencias, mantenimiento preventivo, ordenes de trabajo, repuestos e historial en una sola plataforma.</p>
            <div class="mini-list">
                <div class="mini-item">
                    <div>
                        <strong>Administrador de Flota</strong>
                        <small>Mantiene buses, consulta historial y estadisticas.</small>
                    </div>
                </div>
                <div class="mini-item">
                    <div>
                        <strong>Jefe de Mantenimiento</strong>
                        <small>Programa preventivos, genera ordenes y asigna tecnicos.</small>
                    </div>
                </div>
                <div class="mini-item">
                    <div>
                        <strong>Tecnico y Conductor</strong>
                        <small>Ejecutan mantenimiento, registran repuestos, inspecciones e incidencias.</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="auth-form">
            <h1 style="margin-top:0;">Acceso al sistema</h1>
            <p style="color:var(--muted);">Ingresa para continuar con la gestion operativa del mantenimiento.</p>
            <div class="stat-strip">
                <div><strong>14</strong><span>casos de uso alineados</span></div>
                <div><strong>4</strong><span>actores operativos</span></div>
                <div><strong>1</strong><span>panel central</span></div>
            </div>
            <div class="page-actions" style="margin-top:1.5rem;">
                <a asp-controller="Home" asp-action="Login" class="btn btn-primary">Iniciar sesion</a>
                <a asp-controller="Cuenta" asp-action="OlvidoContrasena" class="btn btn-light">Recuperar contrasena</a>
            </div>
        </div>
    </div>
</section>
