@model SIMCRUL.Common.DTOs.Auth.LoginRequestDto
@{
    ViewData["Title"] = "Iniciar sesion";
    ViewData["HideChrome"] = true;
}

<section class="auth-wrap">
    <div class="auth-card panel">
        <div class="auth-side">
            <span class="chip">Acceso seguro</span>
            <h2>SIMCRUL Mantenimiento</h2>
            <p>Plataforma para administracion de flota, mantenimiento preventivo y correctivo, inspecciones diarias y seguimiento tecnico.</p>
            <div class="mini-list">
                <div class="mini-item">
                    <div>
                        <strong>CU-04 y CU-05</strong>
                        <small>El conductor registra inspecciones e incidencias.</small>
                    </div>
                </div>
                <div class="mini-item">
                    <div>
                        <strong>CU-06 a CU-10</strong>
                        <small>El jefe y el tecnico gestionan ordenes, ejecucion y repuestos.</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="auth-form">
            <h1 style="margin-top:0;">Iniciar sesion</h1>
            <p style="color:var(--muted);">Usa tus credenciales segun el actor asignado.</p>

            <form asp-action="Login" method="post" class="stack" style="margin-top:1.2rem;">
                <div asp-validation-summary="ModelOnly"></div>
                <div class="form-field">
                    <label asp-for="UsernameOrEmail">Usuario o correo</label>
                    <input asp-for="UsernameOrEmail" placeholder="admin.flota o correo institucional" />
                    <span asp-validation-for="UsernameOrEmail"></span>
                </div>
                <div class="form-field">
                    <label asp-for="Password">Contrasena</label>
                    <input asp-for="Password" type="password" placeholder="Tu clave de acceso" />
                    <span asp-validation-for="Password"></span>
                </div>
                <input asp-for="RecaptchaToken" type="hidden" />
                <div class="page-actions">
                    <button type="submit">Ingresar</button>
                    <a asp-controller="Cuenta" asp-action="OlvidoContrasena" class="btn btn-light">Olvide mi contrasena</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
