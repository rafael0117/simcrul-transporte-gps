@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Mantenimiento de Rutas";
}

<div class="page-shell">
    <div class="page-header-actions">
        <div>
            <h1 style="font-size: 2rem; font-weight: 800; background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                <i class="fa-solid fa-route"></i> Mantenimiento de Rutas
            </h1>
            <p style="color: var(--text-secondary); font-size: 0.95rem; margin-top: 0.25rem;">
                Defina y administre las rutas urbanas y velocidades permitidas.
            </p>
        </div>
        <button onclick="openModal()" class="btn-primary">
            <i class="fa-solid fa-plus"></i> Agregar Ruta
        </button>
    </div>

    <div class="glass-card page-filter-bar">
        <div class="page-filter-main">
            <input type="text" id="search-input" onkeyup="filterTable()" class="custom-input" placeholder="Buscar por codigo, nombre o terminales..." style="padding-left: 2.5rem;" />
            <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
        </div>
        <div class="page-filter-toggle">
            <label class="form-label" style="margin-bottom: 0; white-space: nowrap;">Mostrar inactivas</label>
            <input type="checkbox" id="show-deleted" onchange="fetchRoutes()" style="width: 18px; height: 18px; cursor: pointer; accent-color: var(--primary);" />
        </div>
    </div>

    <div class="glass-card responsive-table-card">
        <table id="routes-table">
            <thead>
                <tr style="border-bottom: 2px solid var(--border-color); color: var(--text-secondary); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">
                    <th style="padding: 1rem;">Codigo</th>
                    <th style="padding: 1rem;">Nombre de Ruta</th>
                    <th style="padding: 1rem;">Origen (Terminal A)</th>
                    <th style="padding: 1rem;">Destino (Terminal B)</th>
                    <th style="padding: 1rem; text-align: center;">Distancia</th>
                    <th style="padding: 1rem; text-align: center;">Tiempo Est.</th>
                    <th style="padding: 1rem; text-align: center;">V. Limite</th>
                    <th style="padding: 1rem; text-align: center;">Estado</th>
                    <th style="padding: 1rem; text-align: right;">Acciones</th>
                </tr>
            </thead>
            <tbody id="routes-list">
                <tr>
                    <td colspan="9" style="text-align: center; padding: 3rem; color: var(--text-muted);">
                        <i class="fa-solid fa-spinner fa-spin" style="font-size: 1.5rem; margin-bottom: 0.5rem; display: block;"></i> Cargando rutas...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div id="route-modal" class="modal-overlay">
    <div class="glass-card modal-card">
        <div class="modal-header">
            <h3 id="modal-title" style="font-size: 1.3rem; font-weight: 700; color: white;">
                <i class="fa-solid fa-route"></i> Agregar Ruta
            </h3>
            <button onclick="closeModal()" style="background: none; border: none; color: var(--text-secondary); cursor: pointer; font-size: 1.25rem;">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <form id="route-form" onsubmit="saveRoute(event)" class="modal-form">
            <input type="hidden" id="route-id" name="idRuta" value="0" />

            <div class="form-grid-2">
                <div>
                    <label class="form-label">Codigo Ruta *</label>
                    <input type="text" id="codigo-ruta" name="codigoRuta" class="custom-input" placeholder="Ej: R01" required />
                </div>
                <div>
                    <label class="form-label">Nombre de Ruta *</label>
                    <input type="text" id="nombre-ruta" name="nombreRuta" class="custom-input" placeholder="Ej: SJL - Chorrillos Express" required />
                </div>
            </div>

            <div class="form-grid-2">
                <div>
                    <label class="form-label">Origen (Terminal A) *</label>
                    <input type="text" id="origen" name="origen" class="custom-input" placeholder="Ej: San Juan de Lurigancho" required />
                </div>
                <div>
                    <label class="form-label">Destino (Terminal B) *</label>
                    <input type="text" id="destino" name="destino" class="custom-input" placeholder="Ej: Chorrillos" required />
                </div>
            </div>

            <div class="form-grid-3">
                <div>
                    <label class="form-label">Distancia (km) *</label>
                    <input type="number" id="distancia" name="distanciaKm" class="custom-input" step="0.1" min="0.1" placeholder="Ej: 22.5" required />
                </div>
                <div>
                    <label class="form-label">Tiempo Est (min) *</label>
                    <input type="number" id="tiempo-est" name="tiempoEstimadoMin" class="custom-input" min="1" placeholder="Ej: 75" required />
                </div>
                <div>
                    <label class="form-label">Limite Vel. (km/h) *</label>
                    <input type="number" id="velocidad-max" name="velocidadMaximaKmh" class="custom-input" min="10" placeholder="Ej: 60" required />
                </div>
            </div>

            <div id="estado-container" style="display: none; align-items: center; gap: 0.5rem;">
                <input type="checkbox" id="estado" name="activa" style="width: 18px; height: 18px; cursor: pointer; accent-color: var(--primary);" checked />
                <label class="form-label" style="margin-bottom: 0; cursor: pointer;" for="estado">Ruta Activa</label>
            </div>

            <div class="modal-actions">
                <button type="button" onclick="closeModal()" class="custom-input" style="width: auto; padding: 0.6rem 1.5rem; background: rgba(255,255,255,0.05); color: white; cursor: pointer; border-radius: 8px;">
                    Cancelar
                </button>
                <button type="submit" class="btn-primary" style="border-radius: 8px; padding: 0.6rem 2rem;">
                    Guardar
                </button>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <style>
        #routes-table tbody tr {
            border-bottom: 1px solid var(--border-color);
            transition: background 0.2s;
        }

        #routes-table tbody tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        .status-badge {
            padding: 0.25rem 0.6rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
        }

        .status-active {
            background: rgba(16, 185, 129, 0.15);
            color: var(--success);
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        .status-inactive {
            background: rgba(239, 68, 68, 0.15);
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .btn-action {
            background: none;
            border: none;
            cursor: pointer;
            padding: 0.25rem 0.5rem;
            border-radius: 6px;
            font-size: 0.9rem;
            transition: all 0.2s;
        }

        .btn-edit {
            color: var(--primary);
        }

        .btn-edit:hover {
            background: rgba(6, 182, 212, 0.1);
        }

        .btn-status {
            color: var(--warning);
        }

        .btn-status:hover {
            background: rgba(245, 158, 11, 0.1);
        }
    </style>
}

@section Scripts {
    <script>
        const apiBaseUrl = '@Configuration["ApiSettings:BaseUrl"]';
        const token = '@Context.Session.GetString("Token")';

        let allRoutes = [];

        async function fetchRoutes() {
            const showDeleted = document.getElementById('show-deleted').checked;
            const tbody = document.getElementById('routes-list');

            try {
                const res = await fetch(`${apiBaseUrl}rutas?includeDeleted=${showDeleted}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (res.ok) {
                    allRoutes = await res.json();
                    renderTable(allRoutes);
                } else {
                    tbody.innerHTML = `<tr><td colspan="9" style="text-align:center; padding:2rem; color:var(--danger);">Error al cargar rutas (${res.status}).</td></tr>`;
                }
            } catch (err) {
                console.error(err);
                tbody.innerHTML = `<tr><td colspan="9" style="text-align:center; padding:2rem; color:var(--danger);">Falla de conexion con la API.</td></tr>`;
            }
        }

        function renderTable(list) {
            const tbody = document.getElementById('routes-list');
            if (list.length === 0) {
                tbody.innerHTML = `<tr><td colspan="9" style="text-align:center; padding:3rem; color:var(--text-muted);">No se encontraron rutas.</td></tr>`;
                return;
            }

            tbody.innerHTML = '';
            list.forEach(route => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td style="padding:1rem; font-weight:600; color:var(--primary);">${route.codigoRuta}</td>
                    <td style="padding:1rem; font-weight:700;">${route.nombreRuta}</td>
                    <td style="padding:1rem;">${route.origen}</td>
                    <td style="padding:1rem;">${route.destino}</td>
                    <td style="padding:1rem; text-align:center;">${route.distanciaKm} km</td>
                    <td style="padding:1rem; text-align:center;">${route.tiempoEstimadoMin} min</td>
                    <td style="padding:1rem; text-align:center; color:var(--warning); font-weight:600;">${route.velocidadMaximaKmh} km/h</td>
                    <td style="padding:1rem; text-align:center;">
                        <span class="status-badge ${route.activa ? 'status-active' : 'status-inactive'}">
                            ${route.activa ? 'Activa' : 'Inactiva'}
                        </span>
                    </td>
                    <td style="padding:1rem; text-align:right;">
                        <button onclick="editRoute(${route.idRuta})" class="btn-action btn-edit" title="Editar"><i class="fa-solid fa-pen-to-square"></i></button>
                        <button onclick="toggleRouteStatus(${route.idRuta})" class="btn-action btn-status" title="${route.activa ? 'Desactivar' : 'Activar'}"><i class="fa-solid ${route.activa ? 'fa-toggle-off' : 'fa-toggle-on'}"></i></button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function filterTable() {
            const query = document.getElementById('search-input').value.toLowerCase().trim();
            if (!query) {
                renderTable(allRoutes);
                return;
            }

            const filtered = allRoutes.filter(route =>
                route.codigoRuta.toLowerCase().includes(query) ||
                route.nombreRuta.toLowerCase().includes(query) ||
                route.origen.toLowerCase().includes(query) ||
                route.destino.toLowerCase().includes(query)
            );

            renderTable(filtered);
        }

        function openModal(isEdit = false) {
            const modal = document.getElementById('route-modal');
            modal.classList.add('active');
            document.getElementById('estado-container').style.display = isEdit ? 'flex' : 'none';

            if (!isEdit) {
                document.getElementById('modal-title').innerHTML = '<i class="fa-solid fa-route"></i> Agregar Ruta';
                document.getElementById('route-form').reset();
                document.getElementById('route-id').value = '0';
                document.getElementById('estado').checked = true;
            }
        }

        function closeModal() {
            document.getElementById('route-modal').classList.remove('active');
        }

        function editRoute(id) {
            const route = allRoutes.find(item => item.idRuta === id);
            if (!route) {
                return;
            }

            document.getElementById('modal-title').innerHTML = '<i class="fa-solid fa-route"></i> Editar Ruta';
            document.getElementById('route-id').value = route.idRuta;
            document.getElementById('codigo-ruta').value = route.codigoRuta;
            document.getElementById('nombre-ruta').value = route.nombreRuta;
            document.getElementById('origen').value = route.origen;
            document.getElementById('destino').value = route.destino;
            document.getElementById('distancia').value = route.distanciaKm;
            document.getElementById('tiempo-est').value = route.tiempoEstimadoMin;
            document.getElementById('velocidad-max').value = route.velocidadMaximaKmh;
            document.getElementById('estado').checked = route.activa;

            openModal(true);
        }

        async function saveRoute(e) {
            e.preventDefault();

            const id = parseInt(document.getElementById('route-id').value);
            const payload = {
                idRuta: id,
                codigoRuta: document.getElementById('codigo-ruta').value,
                nombreRuta: document.getElementById('nombre-ruta').value,
                origen: document.getElementById('origen').value,
                destino: document.getElementById('destino').value,
                distanciaKm: parseFloat(document.getElementById('distancia').value),
                tiempoEstimadoMin: parseInt(document.getElementById('tiempo-est').value),
                velocidadMaximaKmh: parseFloat(document.getElementById('velocidad-max').value),
                activa: id === 0 ? true : document.getElementById('estado').checked
            };

            const method = id === 0 ? 'POST' : 'PUT';
            const url = id === 0 ? `${apiBaseUrl}rutas` : `${apiBaseUrl}rutas/${id}`;

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                if (res.ok) {
                    closeModal();
                    fetchRoutes();
                } else {
                    const err = await res.json();
                    alert(`Error al guardar: ${err.message || 'Intente nuevamente'}`);
                }
            } catch (err) {
                alert('Falla de conexion.');
            }
        }

        async function toggleRouteStatus(id) {
            const route = allRoutes.find(item => item.idRuta === id);
            if (!route) {
                return;
            }

            const action = route.activa ? 'desactivar' : 'activar';
            if (!confirm(`Estas seguro que desea ${action} esta ruta?`)) {
                return;
            }

            try {
                const res = await fetch(`${apiBaseUrl}rutas/${id}`, {
                    method: 'PUT',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        ...route,
                        activa: !route.activa
                    })
                });

                if (res.ok) {
                    fetchRoutes();
                } else {
                    const err = await res.json();
                    alert(`Error al actualizar el estado: ${err.message || 'Intente nuevamente'}`);
                }
            } catch (err) {
                alert('Falla de conexion.');
            }
        }

        fetchRoutes();
    </script>
}
