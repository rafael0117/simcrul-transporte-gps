@using SIMCRUL.Web.Infrastructure
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SIMCRUL Mantenimiento</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    @RenderSection("Styles", required: false)
</head>
@{
    var hideChrome = ViewData["HideChrome"] is bool hideChromeValue && hideChromeValue;
    var isAuthenticated = SessionAuthHelper.IsAuthenticated(Context.Session);
    var isAdmin = SessionAuthHelper.IsAdminAuthenticated(Context.Session);
    var isChief = SessionAuthHelper.IsChiefAuthenticated(Context.Session);
    var isTechnician = SessionAuthHelper.IsTechnicianAuthenticated(Context.Session);
    var isDriver = SessionAuthHelper.IsDriverAuthenticated(Context.Session);
    var fullName = $"{Context.Session.GetString("Nombres")} {Context.Session.GetString("Apellidos")}".Trim();
    var role = Context.Session.GetString("Rol") ?? "Invitado";
    var username = Context.Session.GetString("Username") ?? string.Empty;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    string NavClass(string controller, string action = "Index")
    {
        return string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) &&
               string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase)
            ? "nav-link active"
            : "nav-link";
    }
}
<body class="@(hideChrome ? "plain-shell" : "app-shell")">
    @if (hideChrome)
    {
        <main class="plain-main">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="shell">
            <aside class="sidebar">
                <div class="sidebar-glow"></div>
                <a asp-controller="Dashboard" asp-action="Index" class="brand-mark">
                    <span class="brand-icon"><i class="fa-solid fa-screwdriver-wrench"></i></span>
                    <span>
                        <strong>SIMCRUL</strong>
                        <small>Mantenimiento de Flota</small>
                    </span>
                </a>

                <div class="sidebar-meta">
                    <span class="meta-role">@role</span>
                    <span class="meta-user">@fullName</span>
                    @if (!string.IsNullOrWhiteSpace(username))
                    {
                        <span class="meta-username">@username</span>
                    }
                </div>

                <nav class="sidebar-nav">
                    @if (isAuthenticated)
                    {
                        <a asp-controller="Dashboard" asp-action="Index" class="@NavClass("Dashboard")">
                            <i class="fa-solid fa-house"></i> Dashboard
                        </a>
                    }

                    @if (isAdmin)
                    {
                        <a asp-controller="Vehiculos" asp-action="Index" class="@NavClass("Vehiculos")">
                            <i class="fa-solid fa-bus"></i> Vehiculos
                        </a>

                        <a asp-controller="Conductores" asp-action="Index" class="@NavClass("Conductores")">
                            <i class="fa-solid fa-id-card"></i> Conductores
                        </a>
                    }

                    @if (isChief)
                    {
                        <a asp-controller="PlanesMantenimiento" asp-action="Index" class="@NavClass("PlanesMantenimiento")">
                            <i class="fa-solid fa-calendar-check"></i> Preventivos
                        </a>
                    }

                    @if (isChief || isTechnician || isAdmin)
                    {
                        <a asp-controller="OrdenesTrabajo" asp-action="Index" class="@NavClass("OrdenesTrabajo")">
                            <i class="fa-solid fa-clipboard-list"></i> Ordenes
                        </a>
                    }

                    @if (isDriver)
                    {
                        <a asp-controller="Inspecciones" asp-action="Index" class="@NavClass("Inspecciones")">
                            <i class="fa-solid fa-list-check"></i> Inspecciones
                        </a>
                    }

                    @if (isAuthenticated)
                    {
                        <a asp-controller="Incidencias" asp-action="Index" class="@NavClass("Incidencias")">
                            <i class="fa-solid fa-triangle-exclamation"></i> Incidencias
                        </a>
                    }

                    @if (SessionAuthHelper.CanViewHistory(Context.Session))
                    {
                        <a asp-controller="Historial" asp-action="Index" class="@NavClass("Historial")">
                            <i class="fa-solid fa-clock-rotate-left"></i> Historial
                        </a>
                    }

                    @if (SessionAuthHelper.CanViewStats(Context.Session))
                    {
                        <a asp-controller="Estadisticas" asp-action="Index" class="@NavClass("Estadisticas")">
                            <i class="fa-solid fa-chart-column"></i> Estadisticas
                        </a>
                    }
                </nav>

                <div class="sidebar-footer">
                    <a asp-controller="Home" asp-action="Logout" class="ghost-link">
                        <i class="fa-solid fa-right-from-bracket"></i> Cerrar sesion
                    </a>
                </div>
            </aside>

            <div class="content-area">
                <header class="topbar">
                    <div class="topbar-copy">
                        <span class="topbar-kicker">Centro de control</span>
                        <h1>@(ViewData["Title"] ?? "SIMCRUL Mantenimiento")</h1>
                        <p>Control de flota, inspecciones, incidencias y mantenimiento.</p>
                    </div>
                    <div class="topbar-badge">
                        <span>@role</span>
                    </div>
                </header>

                <main class="page-body">
                    @if (TempData["SuccessMessage"] is string successMessage)
                    {
                        <div class="alert success">@successMessage</div>
                    }

                    @if (TempData["ErrorMessage"] is string errorMessage)
                    {
                        <div class="alert error">@errorMessage</div>
                    }

                    @RenderBody()
                </main>
            </div>
        </div>
    }

    @RenderSection("Scripts", required: false)
</body>
</html>
