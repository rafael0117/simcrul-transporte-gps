@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Consulta Pública de Rutas y ETAs";
}

<div class="dashboard-layout" style="max-width: 1400px; margin: 1.5rem auto; padding: 0 1.5rem; gap: 1.5rem; height: calc(100vh - 120px); grid-template-columns: 400px 1fr;">
    <!-- Passenger Controls panel -->
    <div class="glass-card sidebar" style="overflow-y: auto; display: flex; flex-direction: column; gap: 1.5rem;">
        <div>
            <h3 style="margin-bottom: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; color: var(--primary);">
                <i class="fa-solid fa-magnifying-glass-location"></i> Consultar Ruta
            </h3>
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                <div>
                    <label class="form-label">Seleccionar Ruta de Autobús</label>
                    <select id="pass-route-select" class="custom-input" onchange="onRouteChanged()">
                        <option value="">Cargando rutas de tránsito...</option>
                    </select>
                </div>
            </div>
        </div>

        <div id="eta-panel" style="display: none; flex-direction: column; gap: 1.25rem;">
            <h3 style="margin-bottom: 0.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
                <i class="fa-regular fa-clock"></i> Calculador de ETA
            </h3>
            <div>
                <label class="form-label">Paradero Origen</label>
                <select id="stop-origin-select" class="custom-input" onchange="calculateEta()">
                    <option value="">Seleccione origen</option>
                </select>
            </div>
            <div>
                <label class="form-label">Paradero Destino</label>
                <select id="stop-dest-select" class="custom-input" onchange="calculateEta()">
                    <option value="">Seleccione destino</option>
                </select>
            </div>

            <!-- ETA results container -->
            <div class="glass-card" style="background: rgba(6, 182, 212, 0.05); border-color: rgba(6, 182, 212, 0.2); padding: 1.25rem; border-radius: 12px; display: flex; flex-direction: column; gap: 0.75rem;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 0.9rem; color: var(--text-secondary);">Tiempo de Viaje:</span>
                    <span id="eta-travel-time" style="font-weight: 700; color: var(--primary); font-size: 1.1rem;">-- min</span>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 0.9rem; color: var(--text-secondary);">Próximo Bus ETA:</span>
                    <span id="eta-next-bus" style="font-weight: 700; color: var(--success); font-size: 1.1rem;">-- min</span>
                </div>
                <div style="font-size: 0.8rem; color: var(--text-muted); text-align: center; border-top: 1px solid var(--border-color); padding-top: 0.5rem;" id="eta-bus-detail">
                    Seleccione origen y destino para calcular.
                </div>
            </div>
        </div>

        <div>
            <h3 style="margin-bottom: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
                <i class="fa-solid fa-list-check"></i> Paraderos de la Ruta
            </h3>
            <div id="stops-list-container" style="display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.85rem; color: var(--text-secondary);">
                Seleccione una ruta para listar paraderos.
            </div>
        </div>
    </div>

    <!-- Map container -->
    <div class="glass-card" style="padding: 1rem; position: relative;">
        <div id="map" style="height: 100%; border-radius: 12px;"></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        const apiBaseUrl = '@Configuration["ApiSettings:BaseUrl"]';
        const signalrUrl = '@Configuration["ApiSettings:SignalrUrl"]';

        const map = L.map('map').setView([-12.046374, -77.042793], 12);
        
        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; OpenStreetMap &copy; CARTO'
        }).addTo(map);

        let routesList = [];
        let activeRouteDetail = null;
        let routePolyline = null;
        let paraderosMarkers = [];
        let busMarkers = {};

        // Custom Marker Icons
        const paraderoIcon = L.divIcon({
            html: `<div style="display:flex; align-items:center; justify-content:center; width:22px; height:22px; background:#6366f1; border-radius:50%; border:2px solid white; box-shadow:0 0 5px #6366f1;"><i class="fa-solid fa-location-dot" style="color:white; font-size:10px;"></i></div>`,
            iconSize: [22, 22],
            iconAnchor: [11, 11]
        });

        const busIcon = (placa) => L.divIcon({
            html: `<div style="display:flex; align-items:center; justify-content:center; width:36px; height:36px; background:rgba(16, 185, 129, 0.9); border:2px solid white; border-radius:50%; box-shadow:0 0 10px rgba(16,185,129,0.7);"><i class="fa-solid fa-bus" style="color:white; font-size:14px;"></i></div>`,
            iconSize: [36, 36],
            iconAnchor: [18, 18]
        });

        async function fetchRoutes() {
            try {
                const res = await fetch(`${apiBaseUrl}dashboard/routes`);
                if (res.ok) {
                    routesList = await res.json();
                    const select = document.getElementById('pass-route-select');
                    select.innerHTML = '<option value="">-- Seleccione una Ruta --</option>';
                    routesList.forEach(r => {
                        select.innerHTML += `<option value="${r.idRuta}">${r.codigoRuta} - ${r.nombreRuta}</option>`;
                    });
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function onRouteChanged() {
            const routeId = parseInt(document.getElementById('pass-route-select').value);
            if (!routeId) {
                document.getElementById('eta-panel').style.display = 'none';
                return;
            }

            try {
                const res = await fetch(`${apiBaseUrl}dashboard/route/${routeId}/details`);
                if (res.ok) {
                    activeRouteDetail = await res.json();

                    // Clean previous map elements
                    if (routePolyline) map.removeLayer(routePolyline);
                    paraderosMarkers.forEach(m => map.removeLayer(m));
                    paraderosMarkers = [];

                    // Draw route path
                    const points = activeRouteDetail.rutaPuntosControl.map(p => [p.latitud, p.longitud]);
                    if (points.length > 0) {
                        routePolyline = L.polyline(points, { color: 'var(--primary)', weight: 4, opacity: 0.65 }).addTo(map);
                        map.fitBounds(routePolyline.getBounds());
                    }

                    // Populate Stop Selectors
                    const originSelect = document.getElementById('stop-origin-select');
                    const destSelect = document.getElementById('stop-dest-select');
                    const listContainer = document.getElementById('stops-list-container');

                    originSelect.innerHTML = '<option value="">Seleccione origen</option>';
                    destSelect.innerHTML = '<option value="">Seleccione destino</option>';
                    listContainer.innerHTML = '';

                    activeRouteDetail.rutaParaderos.forEach(rp => {
                        const p = rp.paradero;
                        const optionText = `${p.nombre} (Distrito: ${p.distrito})`;
                        
                        originSelect.innerHTML += `<option value="${rp.idRutaParadero}">${optionText}</option>`;
                        destSelect.innerHTML += `<option value="${rp.idRutaParadero}">${optionText}</option>`;

                        // Add stop to side list
                        listContainer.innerHTML += `
                            <div style="padding: 0.4rem; border-bottom: 1px solid var(--border-color); display: flex; gap: 0.5rem; align-items: center;">
                                <i class="fa-solid fa-circle" style="font-size: 6px; color: var(--secondary);"></i>
                                <span>Paradero ${rp.orden}: <strong>${p.nombre}</strong></span>
                            </div>
                        `;

                        // Add stop marker to map
                        const marker = L.marker([p.latitud, p.longitud], { icon: paraderoIcon }).addTo(map);
                        marker.bindPopup(`<strong>Paradero ${rp.orden}:</strong> ${p.nombre}<br>${p.direccionReferencia || ''}`);
                        paraderosMarkers.push(marker);
                    });

                    document.getElementById('eta-panel').style.display = 'flex';
                    calculateEta();

                    // Fetch active vehicles on this route
                    fetchActiveBusesForRoute(routeId);
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function fetchActiveBusesForRoute(routeId) {
            try {
                const res = await fetch(`${apiBaseUrl}dashboard/active-vehicles`);
                if (res.ok) {
                    const vehicles = await res.json();
                    
                    // Clear previous markers
                    Object.values(busMarkers).forEach(m => map.removeLayer(m));
                    busMarkers = {};

                    vehicles.forEach(v => {
                        if (v.idRuta === routeId) {
                            addOrUpdateBusMarker(v);
                        }
                    });
                }
            } catch (err) {
                console.error(err);
            }
        }

        function animateMarkerTo(marker, endLatLng, duration = 3000) {
            const startLatLng = marker.getLatLng();
            const startTime = performance.now();

            function step(now) {
                const elapsed = now - startTime;
                const progress = Math.min(elapsed / duration, 1);

                const currentLat = startLatLng.lat + (endLatLng[0] - startLatLng.lat) * progress;
                const currentLng = startLatLng.lng + (endLatLng[1] - startLatLng.lng) * progress;

                marker.setLatLng([currentLat, currentLng]);

                if (progress < 1) {
                    marker.animationFrameId = requestAnimationFrame(step);
                } else {
                    marker.animationFrameId = null;
                }
            }

            if (marker.animationFrameId) {
                cancelAnimationFrame(marker.animationFrameId);
            }
            marker.animationFrameId = requestAnimationFrame(step);
        }

        function addOrUpdateBusMarker(v) {
            if (!v.latitud || !v.longitud) return;

            const latlng = [v.latitud, v.longitud];
            if (busMarkers[v.idVehiculo]) {
                const marker = busMarkers[v.idVehiculo];
                animateMarkerTo(marker, latlng, 3000);
                marker.bindPopup(`<strong>Placa:</strong> ${v.placa}<br><strong>Velocidad:</strong> ${v.velocidadKmh || 0} km/h`);
            } else {
                const marker = L.marker(latlng, { icon: busIcon(v.placa) }).addTo(map);
                marker.bindPopup(`<strong>Placa:</strong> ${v.placa}<br><strong>Velocidad:</strong> ${v.velocidadKmh || 0} km/h`);
                busMarkers[v.idVehiculo] = marker;
            }
        }

        function calculateEta() {
            const originVal = document.getElementById('stop-origin-select').value;
            const destVal = document.getElementById('stop-dest-select').value;

            if (!originVal || !destVal) {
                document.getElementById('eta-travel-time').textContent = '-- min';
                document.getElementById('eta-next-bus').textContent = '-- min';
                document.getElementById('eta-bus-detail').textContent = 'Seleccione origen y destino para calcular.';
                return;
            }

            const originRp = activeRouteDetail.rutaParaderos.find(rp => rp.idRutaParadero == originVal);
            const destRp = activeRouteDetail.rutaParaderos.find(rp => rp.idRutaParadero == destVal);

            if (!originRp || !destRp) return;

            // Travel time calculation
            const diffTime = destRp.tiempoEstimadoDesdeInicioMin - originRp.tiempoEstimadoDesdeInicioMin;
            if (diffTime < 0) {
                document.getElementById('eta-travel-time').textContent = 'Invalido';
                document.getElementById('eta-bus-detail').textContent = 'Destino debe ser posterior a origen.';
                return;
            }

            document.getElementById('eta-travel-time').textContent = `${diffTime} min`;

            // Calculate distance & ETA to origin from nearest bus
            let nearestBus = null;
            let minDistance = Infinity;

            Object.entries(busMarkers).forEach(([id, m]) => {
                const busLatLng = m.getLatLng();
                const distance = calculateDistance(
                    busLatLng.lat, 
                    busLatLng.lng, 
                    originRp.paradero.latitud, 
                    originRp.paradero.longitud
                );

                if (distance < minDistance) {
                    minDistance = distance;
                    // Find actual velocity from popup context or list
                    nearestBus = {
                        distance: distance
                    };
                }
            });

            if (nearestBus) {
                // assume avg speed of 30 km/h (8.3 m/s) in traffic
                const etaMin = Math.round((nearestBus.distance / 8.3) / 60);
                document.getElementById('eta-next-bus').textContent = `${etaMin} min`;
                document.getElementById('eta-bus-detail').innerHTML = `<i class="fa-solid fa-circle-check"></i> El bus más cercano está a <strong>${(nearestBus.distance / 1000).toFixed(1)} km</strong> de distancia.`;
            } else {
                document.getElementById('eta-next-bus').textContent = 'No disponible';
                document.getElementById('eta-bus-detail').textContent = 'No hay buses activos en esta ruta actualmente.';
            }
        }

        function calculateDistance(lat1, lon1, lat2, lon2) {
            const R = 6371000;
            const dLat = (lat2 - lat1) * Math.PI / 180;
            const dLon = (lon2 - lon1) * Math.PI / 180;
            const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
                      Math.Cos(lat1 * Math.PI / 180) * Math.Cos(lat2 * Math.PI / 180) *
                      Math.sin(dLon/2) * Math.sin(dLon/2);
            const c = 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1-a));
            return R * c;
        }

        // Establish real-time listener for passenger map updates
        const connection = new signalR.HubConnectionBuilder()
            .withUrl(signalrUrl)
            .withAutomaticReconnect()
            .build();

        connection.on("SendTelemetryUpdate", (v) => {
            const routeId = parseInt(document.getElementById('pass-route-select').value);
            if (v.idRuta === routeId) {
                addOrUpdateBusMarker(v);
                calculateEta();
            }
        });

        async function startSignalR() {
            try {
                await connection.start();
                console.log("Passenger Hub Connected");
            } catch (err) {
                setTimeout(startSignalR, 5000);
            }
        }

        fetchRoutes();
        startSignalR();
    </script>
}
