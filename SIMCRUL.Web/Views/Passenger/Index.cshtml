@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Consulta Publica de Rutas y ETA";
    var googleMapsApiKey = Configuration["GoogleMaps:ApiKey"] ?? string.Empty;
    var useGoogleMaps = bool.TryParse(Configuration["GoogleMaps:UseGoogleMaps"], out var enabled) && enabled;
    var hasGoogleMapsKey = !string.IsNullOrWhiteSpace(googleMapsApiKey);
}

<div class="dashboard-layout dashboard-shell" style="height: calc(100vh - 120px); grid-template-columns: 400px 1fr;">
    <div class="glass-card sidebar" style="overflow-y: auto; display: flex; flex-direction: column; gap: 1.5rem;">
        <div>
            <h3 style="margin-bottom: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; color: var(--primary);">
                <i class="fa-solid fa-magnifying-glass-location"></i> Consultar Ruta
            </h3>
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                <div>
                    <label class="form-label">Seleccionar Ruta de autobus</label>
                    <select id="pass-route-select" class="custom-input" onchange="onRouteChanged()">
                        <option value="">Cargando rutas de transito...</option>
                    </select>
                </div>
            </div>
            <div class="glass-card" style="margin-top: 1rem; padding: 0.85rem 1rem; border-radius: 12px; background: rgba(6, 182, 212, 0.06); border-color: rgba(6, 182, 212, 0.16);">
                <div class="info-row">
                    <span style="font-size: 0.85rem; color: var(--text-secondary);">Motor de mapa</span>
                    <strong id="map-provider-label" style="font-size: 0.9rem; color: var(--primary);">
                        @(useGoogleMaps && hasGoogleMapsKey ? "Google Maps" : "Leaflet")
                    </strong>
                </div>
                @if (!hasGoogleMapsKey)
                {
                    <p style="margin-top: 0.65rem; font-size: 0.8rem; color: var(--text-muted);">
                        Agrega tu API key en <code>SIMCRUL.Web/appsettings.json</code> para mostrar la ruta real de Google Maps.
                    </p>
                }
            </div>

            <div class="glass-card" style="margin-top: 1rem; padding: 1rem; border-radius: 12px; background: rgba(16, 185, 129, 0.06); border-color: rgba(16, 185, 129, 0.18); display: flex; flex-direction: column; gap: 0.85rem;">
                <div class="info-row">
                    <span style="font-size: 0.85rem; color: var(--text-secondary);">Telemetria activa en esta ruta</span>
                    <strong id="route-bus-count" style="font-size: 0.9rem; color: var(--success);">0 buses</strong>
                </div>
                <div style="font-size: 0.78rem; color: var(--text-muted); line-height: 1.5;">
                    El monitoreo se actualiza automaticamente con las posiciones reportadas por la flota. Selecciona una ruta para ver sus unidades activas en el mapa.
                </div>
            </div>
        </div>

        <div>
            <h3 style="margin-bottom: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
                <i class="fa-solid fa-bus"></i> Proximos Buses
            </h3>
            <div id="active-buses-container" style="display: flex; flex-direction: column; gap: 0.75rem; font-size: 0.85rem; color: var(--text-secondary);">
                Selecciona una ruta para ver los buses disponibles y su tiempo estimado de llegada.
            </div>
        </div>

        <div>
            <h3 style="margin-bottom: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
                <i class="fa-solid fa-list-check"></i> Paraderos de la Ruta
            </h3>
            <div id="stops-list-container" style="display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.85rem; color: var(--text-secondary);">
                Seleccione una ruta para listar paraderos.
            </div>
        </div>
    </div>

    <div class="glass-card map-card">
        <div id="map"></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        const apiBaseUrl = '@Configuration["ApiSettings:BaseUrl"]';
        const signalrUrl = '@Configuration["ApiSettings:SignalrUrl"]';
        const useGoogleMaps = @((useGoogleMaps && hasGoogleMapsKey).ToString().ToLowerInvariant());
        const googleMapsApiKey = '@googleMapsApiKey';

        let routesList = [];
        let activeRouteDetail = null;
        let selectedRouteId = null;
        let activeVehiclesForRoute = [];
        let busMarkers = {};
        let stopMarkers = [];
        let routeRenderElement = null;
        let routePolyline = null;

        let leafletMap = null;
        let googleMap = null;
        let googleInfoWindow = null;
        let googleDirectionsService = null;
        let googleDirectionsRenderer = null;
        let googleMapsLibrary = null;
        const googleBusMarkerSvg = `
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 64 64">
                <defs>
                    <linearGradient id="busBody" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" stop-color="#34d399" />
                        <stop offset="100%" stop-color="#0f766e" />
                    </linearGradient>
                </defs>
                <g>
                    <path d="M18 8h28c6 0 10 4 10 10v18c0 4-2 7-5 9v7c0 2-1 4-3 4h-2c-2 0-3-2-3-4v-4H21v4c0 2-1 4-3 4h-2c-2 0-3-2-3-4v-7c-3-2-5-5-5-9V18c0-6 4-10 10-10z" fill="url(#busBody)" />
                    <rect x="15" y="16" width="34" height="11" rx="4" fill="#ecfeff" opacity="0.95" />
                    <rect x="15" y="30" width="34" height="10" rx="4" fill="#99f6e4" opacity="0.92" />
                    <circle cx="21" cy="48" r="6" fill="#0f172a" />
                    <circle cx="43" cy="48" r="6" fill="#0f172a" />
                    <circle cx="21" cy="48" r="2.4" fill="#cbd5e1" />
                    <circle cx="43" cy="48" r="2.4" fill="#cbd5e1" />
                    <path d="M12 41h40" stroke="#083344" stroke-width="3" stroke-linecap="round" opacity="0.35" />
                </g>
            </svg>`;
        const googleBusMarkerIcon = {
            url: `data:image/svg+xml;charset=UTF-8,${encodeURIComponent(googleBusMarkerSvg)}`,
            scaledSize: null,
            anchor: null
        };

        const initialCenter = { lat: -12.046374, lng: -77.042793 };

        const paraderoIcon = L.divIcon({
            html: `<div style="display:flex; align-items:center; justify-content:center; width:22px; height:22px; background:#6366f1; border-radius:50%; border:2px solid white; box-shadow:0 0 5px #6366f1;"><i class="fa-solid fa-location-dot" style="color:white; font-size:10px;"></i></div>`,
            iconSize: [22, 22],
            iconAnchor: [11, 11]
        });

        const busIcon = () => L.divIcon({
            html: `
                <div style="display:flex; align-items:center; justify-content:center; width:42px; height:42px; filter: drop-shadow(0 10px 14px rgba(15, 118, 110, 0.32));">
                    ${googleBusMarkerSvg}
                </div>`,
            className: '',
            iconSize: [42, 42],
            iconAnchor: [21, 21]
        });

        async function loadGoogleMapsApi() {
            if (window.google && window.google.maps) {
                return;
            }

            await new Promise((resolve, reject) => {
                const script = document.createElement('script');
                script.src = `https://maps.googleapis.com/maps/api/js?key=${googleMapsApiKey}&libraries=routes&v=weekly`;
                script.async = true;
                script.defer = true;
                script.onload = resolve;
                script.onerror = reject;
                document.head.appendChild(script);
            });
        }

        async function initializeMap() {
            if (useGoogleMaps) {
                try {
                    await loadGoogleMapsApi();
                    const { Map, InfoWindow } = await google.maps.importLibrary('maps');
                    const { DirectionsService, DirectionsRenderer } = await google.maps.importLibrary('routes');

                    googleMapsLibrary = google.maps;
                    googleBusMarkerIcon.scaledSize = new googleMapsLibrary.Size(44, 44);
                    googleBusMarkerIcon.anchor = new googleMapsLibrary.Point(22, 22);
                    googleMap = new Map(document.getElementById('map'), {
                        center: initialCenter,
                        zoom: 12,
                        mapTypeControl: false,
                        streetViewControl: false,
                        fullscreenControl: true
                    });

                    googleInfoWindow = new InfoWindow();
                    googleDirectionsService = new DirectionsService();
                    googleDirectionsRenderer = new DirectionsRenderer({
                        map: googleMap,
                        suppressMarkers: true,
                        polylineOptions: {
                            strokeColor: '#06b6d4',
                            strokeOpacity: 0.85,
                            strokeWeight: 5
                        }
                    });

                    return;
                } catch (error) {
                    console.error('No se pudo cargar Google Maps, se usara Leaflet.', error);
                    document.getElementById('map-provider-label').textContent = 'Leaflet';
                }
            }

            leafletMap = L.map('map').setView([initialCenter.lat, initialCenter.lng], 12);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap &copy; CARTO'
            }).addTo(leafletMap);
        }

        function clearRouteVisuals() {
            stopMarkers.forEach(removeMarkerFromMap);
            stopMarkers = [];

            Object.values(busMarkers).forEach(removeMarkerFromMap);
            busMarkers = {};
            activeVehiclesForRoute = [];
            updateRouteBusCount();
            renderActiveBusesList();

            if (useGoogleMaps && googleDirectionsRenderer) {
                googleDirectionsRenderer.set('directions', null);
                if (routePolyline) {
                    routePolyline.setMap(null);
                    routePolyline = null;
                }
            }

            if (!useGoogleMaps && leafletMap && routePolyline) {
                leafletMap.removeLayer(routePolyline);
                routePolyline = null;
            }
        }

        function removeMarkerFromMap(marker) {
            if (!marker) {
                return;
            }

            if (useGoogleMaps && marker.setMap) {
                marker.setMap(null);
                return;
            }

            if (!useGoogleMaps && leafletMap) {
                leafletMap.removeLayer(marker);
            }
        }

        function updateRouteBusCount() {
            const total = Object.keys(busMarkers).length;
            document.getElementById('route-bus-count').textContent = `${total} bus${total === 1 ? '' : 'es'}`;
        }

        function animateCoordinateTransition(from, to, onUpdate, durationMs = 2200) {
            const startedAt = performance.now();

            const step = (now) => {
                const progress = Math.min((now - startedAt) / durationMs, 1);
                const eased = 0.5 - (Math.cos(Math.PI * progress) / 2);
                const nextPosition = {
                    lat: from.lat + ((to.lat - from.lat) * eased),
                    lng: from.lng + ((to.lng - from.lng) * eased)
                };

                onUpdate(nextPosition);

                if (progress < 1) {
                    return requestAnimationFrame(step);
                }

                return null;
            };

            return requestAnimationFrame(step);
        }

        function animateMarkerTo(marker, targetPosition) {
            if (useGoogleMaps && marker.getPosition) {
                const currentPosition = marker.getPosition();
                const origin = currentPosition
                    ? { lat: currentPosition.lat(), lng: currentPosition.lng() }
                    : targetPosition;

                if (marker.__animationFrame) {
                    cancelAnimationFrame(marker.__animationFrame);
                }

                marker.__animationFrame = animateCoordinateTransition(origin, targetPosition, (position) => {
                    marker.setPosition(position);
                });
                return;
            }

            const currentPosition = marker.getLatLng();
            const origin = currentPosition
                ? { lat: currentPosition.lat, lng: currentPosition.lng }
                : targetPosition;

            if (marker.__animationFrame) {
                cancelAnimationFrame(marker.__animationFrame);
            }

            marker.__animationFrame = animateCoordinateTransition(origin, targetPosition, (position) => {
                marker.setLatLng([position.lat, position.lng]);
            });
        }

        function renderStops(routeDetail) {
            const listContainer = document.getElementById('stops-list-container');

            listContainer.innerHTML = '';

            routeDetail.rutaParaderos.forEach(rp => {
                const stop = rp.paradero;

                listContainer.innerHTML += `
                    <div style="padding: 0.4rem; border-bottom: 1px solid var(--border-color); display: flex; gap: 0.5rem; align-items: center;">
                        <i class="fa-solid fa-circle" style="font-size: 6px; color: var(--secondary);"></i>
                        <span>Paradero ${rp.orden}: <strong>${stop.nombre}</strong></span>
                    </div>
                `;

                addStopMarker(stop, rp.orden);
            });
        }

        function estimateBusEta(vehicle) {
            if (!activeRouteDetail?.rutaParaderos?.length) {
                return null;
            }

            let nearestRouteStop = null;
            let nearestDistance = Infinity;

            activeRouteDetail.rutaParaderos.forEach(routeStop => {
                const distance = calculateDistance(
                    Number(vehicle.latitud),
                    Number(vehicle.longitud),
                    Number(routeStop.paradero.latitud),
                    Number(routeStop.paradero.longitud)
                );

                if (distance < nearestDistance) {
                    nearestDistance = distance;
                    nearestRouteStop = routeStop;
                }
            });

            if (!nearestRouteStop) {
                return null;
            }

            const distanceMeters = calculateDistance(
                Number(vehicle.latitud),
                Number(vehicle.longitud),
                Number(nearestRouteStop.paradero.latitud),
                Number(nearestRouteStop.paradero.longitud)
            );

            const speedKmh = Math.max(Number(vehicle.velocidadKmh) || 24, 14);
            const etaMinutes = Math.max(1, Math.round((distanceMeters / 1000) / speedKmh * 60));

            return {
                stopName: nearestRouteStop.paradero.nombre,
                hintLabel: 'Paradero cercano',
                distanceKm: distanceMeters / 1000,
                etaMinutes
            };
        }

        function renderActiveBusesList() {
            const container = document.getElementById('active-buses-container');

            if (!selectedRouteId) {
                container.innerHTML = 'Selecciona una ruta para ver los buses disponibles y su tiempo estimado de llegada.';
                return;
            }

            if (!activeVehiclesForRoute.length) {
                container.innerHTML = 'No hay buses activos reportando en esta ruta en este momento.';
                return;
            }

            const orderedVehicles = activeVehiclesForRoute
                .slice()
                .sort((left, right) => {
                    const leftEta = estimateBusEta(left)?.etaMinutes ?? Number.MAX_SAFE_INTEGER;
                    const rightEta = estimateBusEta(right)?.etaMinutes ?? Number.MAX_SAFE_INTEGER;
                    return leftEta - rightEta;
                });

            container.innerHTML = orderedVehicles.map(vehicle => {
                const eta = estimateBusEta(vehicle);
                const etaText = eta ? `${eta.etaMinutes} min` : '--';
                const etaHint = eta
                    ? `${eta.hintLabel}: ${eta.stopName} • ${eta.distanceKm.toFixed(1)} km`
                    : 'Esperando una ubicacion valida.';

                return `
                    <div style="padding: 0.85rem; border-radius: 14px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); display: flex; gap: 0.85rem; align-items: flex-start;">
                        <div style="width: 42px; height: 42px; display:flex; align-items:center; justify-content:center; flex-shrink: 0;">
                            ${googleBusMarkerSvg}
                        </div>
                        <div style="flex: 1; min-width: 0;">
                            <div class="info-row info-row-top">
                                <strong style="color: var(--text-primary); font-size: 0.92rem;">${vehicle.placa}</strong>
                                <span style="font-weight: 700; color: var(--success); font-size: 0.95rem;">${etaText}</span>
                            </div>
                            <div style="margin-top: 0.2rem; color: var(--text-secondary); font-size: 0.8rem;">
                                ${vehicle.codigoInterno || 'Unidad'} • ${Math.round(Number(vehicle.velocidadKmh) || 0)} km/h
                            </div>
                            <div style="margin-top: 0.35rem; color: var(--text-muted); font-size: 0.78rem;">
                                ${etaHint}
                            </div>
                        </div>
                    </div>`;
            }).join('');
        }

        function addStopMarker(stop, order) {
            if (useGoogleMaps && googleMap) {
                const marker = new google.maps.Marker({
                    position: { lat: Number(stop.latitud), lng: Number(stop.longitud) },
                    map: googleMap,
                    title: `Paradero ${order}: ${stop.nombre}`,
                    icon: {
                        path: googleMapsLibrary.SymbolPath.CIRCLE,
                        fillColor: '#6366f1',
                        fillOpacity: 1,
                        strokeColor: '#ffffff',
                        strokeWeight: 2,
                        scale: 7
                    }
                });

                marker.addListener('click', () => {
                    googleInfoWindow.setContent(`<strong>Paradero ${order}:</strong> ${stop.nombre}<br>${stop.direccionReferencia || ''}`);
                    googleInfoWindow.open({ anchor: marker, map: googleMap });
                });

                stopMarkers.push(marker);
                return;
            }

            const marker = L.marker([stop.latitud, stop.longitud], { icon: paraderoIcon }).addTo(leafletMap);
            marker.bindPopup(`<strong>Paradero ${order}:</strong> ${stop.nombre}<br>${stop.direccionReferencia || ''}`);
            stopMarkers.push(marker);
        }

        async function renderRouteOnMap(routeDetail) {
            const controlPoints = routeDetail.rutaPuntosControl
                .slice()
                .sort((a, b) => a.orden - b.orden);

            if (controlPoints.length === 0) {
                return;
            }

            if (useGoogleMaps && googleDirectionsService && googleDirectionsRenderer) {
                const origin = {
                    lat: Number(controlPoints[0].latitud),
                    lng: Number(controlPoints[0].longitud)
                };

                const destination = {
                    lat: Number(controlPoints[controlPoints.length - 1].latitud),
                    lng: Number(controlPoints[controlPoints.length - 1].longitud)
                };

                const waypoints = controlPoints.slice(1, -1).map(point => ({
                    location: {
                        lat: Number(point.latitud),
                        lng: Number(point.longitud)
                    },
                    stopover: false
                }));

                try {
                    const response = await googleDirectionsService.route({
                        origin,
                        destination,
                        waypoints,
                        optimizeWaypoints: false,
                        travelMode: googleMapsLibrary.TravelMode.DRIVING
                    });

                    googleDirectionsRenderer.setDirections(response);
                    if (response.routes?.length) {
                        const bounds = response.routes[0].bounds;
                        if (bounds) {
                            googleMap.fitBounds(bounds);
                        }
                    }
                    return;
                } catch (error) {
                    console.error('No se pudo calcular la ruta con Google Directions. Se dibujara la polilinea base.', error);
                    const fallbackPath = controlPoints.map(point => ({
                        lat: Number(point.latitud),
                        lng: Number(point.longitud)
                    }));

                    routePolyline = new google.maps.Polyline({
                        map: googleMap,
                        path: fallbackPath,
                        strokeColor: '#06b6d4',
                        strokeOpacity: 0.85,
                        strokeWeight: 5
                    });

                    const bounds = new google.maps.LatLngBounds();
                    fallbackPath.forEach(point => bounds.extend(point));
                    googleMap.fitBounds(bounds);
                    return;
                }
            }

            const points = controlPoints.map(point => [point.latitud, point.longitud]);
            routePolyline = L.polyline(points, { color: 'var(--primary)', weight: 4, opacity: 0.65 }).addTo(leafletMap);
            leafletMap.fitBounds(routePolyline.getBounds());
        }

        async function fetchRoutes() {
            try {
                const res = await fetch(`${apiBaseUrl}dashboard/routes`);
                if (!res.ok) {
                    return;
                }

                routesList = await res.json();
                const select = document.getElementById('pass-route-select');
                select.innerHTML = '<option value="">-- Seleccione una Ruta --</option>';
                routesList.forEach(route => {
                    select.innerHTML += `<option value="${route.idRuta}">${route.codigoRuta} - ${route.nombreRuta}</option>`;
                });
            } catch (err) {
                console.error(err);
            }
        }

        async function onRouteChanged() {
            const routeId = parseInt(document.getElementById('pass-route-select').value);
            selectedRouteId = routeId || null;
            if (!routeId) {
                clearRouteVisuals();
                return;
            }

            try {
                const res = await fetch(`${apiBaseUrl}dashboard/route/${routeId}/details`);
                if (!res.ok) {
                    return;
                }

                activeRouteDetail = await res.json();
                clearRouteVisuals();
                renderStops(activeRouteDetail);
                await renderRouteOnMap(activeRouteDetail);
                await fetchActiveBusesForRoute(routeId);
            } catch (err) {
                console.error(err);
            }
        }

        async function fetchActiveBusesForRoute(routeId) {
            try {
                const res = await fetch(`${apiBaseUrl}dashboard/active-vehicles`);
                if (!res.ok) {
                    return;
                }

                const vehicles = await res.json();
                Object.values(busMarkers).forEach(removeMarkerFromMap);
                busMarkers = {};
                activeVehiclesForRoute = [];

                vehicles.forEach(vehicle => {
                    if (vehicle.idRuta === routeId) {
                        activeVehiclesForRoute.push(vehicle);
                        addOrUpdateBusMarker(vehicle);
                    }
                });
                updateRouteBusCount();
                renderActiveBusesList();
            } catch (err) {
                console.error(err);
            }
        }

        function addOrUpdateBusMarker(vehicle) {
            if (!vehicle.latitud || !vehicle.longitud) {
                return;
            }

            if (useGoogleMaps && googleMap) {
                const position = {
                    lat: Number(vehicle.latitud),
                    lng: Number(vehicle.longitud)
                };

                if (busMarkers[vehicle.idVehiculo]) {
                    animateMarkerTo(busMarkers[vehicle.idVehiculo], position);
                    return;
                }

                const marker = new google.maps.Marker({
                    position,
                    map: googleMap,
                    title: vehicle.placa,
                    icon: googleBusMarkerIcon
                });

                marker.addListener('click', () => {
                    const eta = estimateBusEta(vehicle);
                    googleInfoWindow.setContent(`
                        <strong>${vehicle.placa}</strong><br>
                        Velocidad: ${Math.round(vehicle.velocidadKmh || 0)} km/h<br>
                        ${eta ? `ETA: ${eta.etaMinutes} min a ${eta.stopName}` : 'ETA no disponible'}
                    `);
                    googleInfoWindow.open({ anchor: marker, map: googleMap });
                });

                busMarkers[vehicle.idVehiculo] = marker;
                updateRouteBusCount();
                return;
            }

            const latlng = [vehicle.latitud, vehicle.longitud];
            if (busMarkers[vehicle.idVehiculo]) {
                animateMarkerTo(busMarkers[vehicle.idVehiculo], {
                    lat: Number(vehicle.latitud),
                    lng: Number(vehicle.longitud)
                });
                busMarkers[vehicle.idVehiculo].bindPopup(`<strong>Placa:</strong> ${vehicle.placa}<br><strong>Velocidad:</strong> ${vehicle.velocidadKmh || 0} km/h`);
                return;
            }

            const marker = L.marker(latlng, { icon: busIcon() }).addTo(leafletMap);
            const eta = estimateBusEta(vehicle);
            marker.bindPopup(`
                <strong>${vehicle.placa}</strong><br>
                Velocidad: ${Math.round(vehicle.velocidadKmh || 0)} km/h<br>
                ${eta ? `ETA: ${eta.etaMinutes} min a ${eta.stopName}` : 'ETA no disponible'}
            `);
            busMarkers[vehicle.idVehiculo] = marker;
            updateRouteBusCount();
        }

        function getMarkerPosition(marker) {
            if (useGoogleMaps && marker.getPosition) {
                const position = marker.getPosition();
                return {
                    lat: position.lat(),
                    lng: position.lng()
                };
            }

            const position = marker.getLatLng();
            return {
                lat: position.lat,
                lng: position.lng
            };
        }

        function calculateDistance(lat1, lon1, lat2, lon2) {
            const radius = 6371000;
            const dLat = (lat2 - lat1) * Math.PI / 180;
            const dLon = (lon2 - lon1) * Math.PI / 180;
            const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                      Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
                      Math.sin(dLon / 2) * Math.sin(dLon / 2);
            const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
            return radius * c;
        }

        const connection = new signalR.HubConnectionBuilder()
            .withUrl(signalrUrl)
            .withAutomaticReconnect()
            .build();

        connection.on("SendTelemetryUpdate", (vehicle) => {
            const routeId = parseInt(document.getElementById('pass-route-select').value);
            if (vehicle.idRuta === routeId) {
                const currentIndex = activeVehiclesForRoute.findIndex(currentVehicle => currentVehicle.idVehiculo === vehicle.idVehiculo);
                if (currentIndex >= 0) {
                    activeVehiclesForRoute[currentIndex] = vehicle;
                } else {
                    activeVehiclesForRoute.push(vehicle);
                }

                addOrUpdateBusMarker(vehicle);
                updateRouteBusCount();
                renderActiveBusesList();
            }
        });

        async function startSignalR() {
            try {
                await connection.start();
                console.log("Passenger Hub Connected");
            } catch (error) {
                setTimeout(startSignalR, 5000);
            }
        }

        async function bootstrapPassengerMap() {
            await initializeMap();
            await fetchRoutes();
            await startSignalR();
        }

        bootstrapPassengerMap();
    </script>
}
