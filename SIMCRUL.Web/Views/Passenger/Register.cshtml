@model SIMCRUL.Common.DTOs.Auth.RegisterRequestDto
@{
    ViewData["Title"] = "Registro de Pasajeros";
    var returnUrl = ViewBag.ReturnUrl as string;
}

<div class="centered-page">
    <div class="glass-card login-card" style="max-width: 760px;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <i class="fa-solid fa-id-card-clip" style="font-size: 3rem; color: var(--secondary); margin-bottom: 1rem;"></i>
            <h2>Crear cuenta de pasajero</h2>
            <p style="color: var(--text-secondary); font-size: 0.92rem; margin-top: 0.4rem;">
                Registra tu cuenta para descargar rutas en PDF y enviar reclamos o peticiones.
            </p>
        </div>

        <form asp-action="Register" method="post" class="modal-form" style="gap: 1.25rem;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@returnUrl" />
            <div asp-validation-summary="ModelOnly" style="color: var(--danger); font-size: 0.9rem;"></div>

            <div class="form-grid-2">
                <div>
                    <label asp-for="Nombres" class="form-label">Nombres</label>
                    <input asp-for="Nombres" class="custom-input" />
                    <span asp-validation-for="Nombres" style="color: var(--danger); font-size: 0.8rem; display: block; margin-top: 0.25rem;"></span>
                </div>
                <div>
                    <label asp-for="Apellidos" class="form-label">Apellidos</label>
                    <input asp-for="Apellidos" class="custom-input" />
                    <span asp-validation-for="Apellidos" style="color: var(--danger); font-size: 0.8rem; display: block; margin-top: 0.25rem;"></span>
                </div>
            </div>

            <div class="form-grid-2">
                <div>
                    <label asp-for="Username" class="form-label">Usuario</label>
                    <input asp-for="Username" class="custom-input" autocomplete="username" />
                    <span asp-validation-for="Username" style="color: var(--danger); font-size: 0.8rem; display: block; margin-top: 0.25rem;"></span>
                </div>
                <div>
                    <label asp-for="Email" class="form-label">Correo</label>
                    <input asp-for="Email" class="custom-input" autocomplete="email" />
                    <span asp-validation-for="Email" style="color: var(--danger); font-size: 0.8rem; display: block; margin-top: 0.25rem;"></span>
                </div>
            </div>

            <div class="form-grid-2">
                <div>
                    <label asp-for="Telefono" class="form-label">Telefono</label>
                    <input asp-for="Telefono" class="custom-input" />
                    <span asp-validation-for="Telefono" style="color: var(--danger); font-size: 0.8rem; display: block; margin-top: 0.25rem;"></span>
                </div>
                <div>
                    <label asp-for="Password" class="form-label">Contrasena</label>
                    <input asp-for="Password" type="password" class="custom-input" autocomplete="new-password" />
                    <span asp-validation-for="Password" style="color: var(--danger); font-size: 0.8rem; display: block; margin-top: 0.25rem;"></span>
                </div>
            </div>

            <button type="submit" class="btn-primary" style="width: 100%; padding: 0.85rem; border-radius: 12px;">
                <i class="fa-solid fa-user-check"></i> Crear cuenta
            </button>
        </form>

        <div style="margin-top: 1rem; text-align: center;">
            <a asp-controller="Passenger" asp-action="Login" asp-route-returnUrl="@returnUrl" style="color: var(--primary); font-weight: 600; text-decoration: none;">
                <i class="fa-solid fa-arrow-right-to-bracket"></i> Ya tengo una cuenta
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
