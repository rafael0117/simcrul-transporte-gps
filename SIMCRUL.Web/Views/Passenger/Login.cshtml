@model SIMCRUL.Common.DTOs.Auth.LoginRequestDto
@{
    ViewData["Title"] = "Acceso de Pasajeros";
    var returnUrl = ViewBag.ReturnUrl as string;
}

<div class="centered-page">
    <div class="glass-card login-card">
        <div style="text-align: center; margin-bottom: 2rem;">
            <i class="fa-solid fa-bus-simple" style="font-size: 3rem; color: var(--success); margin-bottom: 1rem;"></i>
            <h2>Acceso de Pasajeros</h2>
            <p style="color: var(--text-secondary); font-size: 0.92rem; margin-top: 0.4rem;">
                Inicia sesion para descargar el catalogo de rutas y registrar reclamos o peticiones.
            </p>
        </div>

        <form asp-action="Login" method="post" class="modal-form" style="gap: 1.25rem;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@returnUrl" />
            <div asp-validation-summary="ModelOnly" style="color: var(--danger); font-size: 0.9rem;"></div>

            <div>
                <label asp-for="UsernameOrEmail" class="form-label">Usuario o correo</label>
                <input asp-for="UsernameOrEmail" class="custom-input" placeholder="usuario o correo" autocomplete="username" />
                <span asp-validation-for="UsernameOrEmail" style="color: var(--danger); font-size: 0.8rem; margin-top: 0.25rem; display: block;"></span>
            </div>

            <div>
                <label asp-for="Password" class="form-label">Contrasena</label>
                <input asp-for="Password" type="password" class="custom-input" placeholder="********" autocomplete="current-password" />
                <span asp-validation-for="Password" style="color: var(--danger); font-size: 0.8rem; margin-top: 0.25rem; display: block;"></span>
            </div>

            <button type="submit" class="btn-primary" style="width: 100%; padding: 0.85rem; border-radius: 12px;">
                <i class="fa-solid fa-arrow-right-to-bracket"></i> Ingresar
            </button>
        </form>

        <div style="margin-top: 1rem; text-align: center;">
            <a asp-controller="Cuenta" asp-action="OlvidoContrasena" asp-route-origen="passenger" style="color: var(--primary); font-weight: 600; text-decoration: none;">
                <i class="fa-solid fa-key"></i> Recuperar contrasena
            </a>
        </div>

        <div style="margin-top: 1rem; text-align: center;">
            <a asp-controller="Passenger" asp-action="Register" asp-route-returnUrl="@returnUrl" style="color: var(--primary); font-weight: 600; text-decoration: none;">
                <i class="fa-solid fa-user-plus"></i> Crear cuenta de pasajero
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
