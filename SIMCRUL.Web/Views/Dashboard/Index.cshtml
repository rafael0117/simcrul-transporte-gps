@model SIMCRUL.Common.DTOs.Maintenance.MaintenanceDashboardDto
@using SIMCRUL.Web.Infrastructure
@{
    ViewData["Title"] = "Dashboard";
    var role = Context.Session.GetString("Rol") ?? string.Empty;
    var health = Model.VehiculosFueraDeServicio > 0
        ? "Atencion inmediata"
        : Model.VehiculosEnMantenimiento > 0
            ? "Operacion controlada"
            : "Flota estable";
}

<section class="dashboard-hero">
    <div class="dashboard-hero__copy">
        <span class="hero-label">Resumen operativo</span>
        <h2>@(ViewBag.DisplayName ?? "Usuario")</h2>
        <p>Rol activo: @role. Desde aqui puedes revisar el pulso del mantenimiento y entrar directo a las acciones criticas del dia.</p>
        <div class="hero-actions">
            @if (SessionAuthHelper.IsAdminAuthenticated(Context.Session))
            {
                <a asp-controller="Vehiculos" asp-action="Index" class="btn btn-light">Mantener vehiculos</a>
            }
            @if (SessionAuthHelper.IsChiefAuthenticated(Context.Session))
            {
                <a asp-controller="PlanesMantenimiento" asp-action="Index" class="btn btn-light">Programar preventivo</a>
            }
            @if (SessionAuthHelper.IsTechnicianAuthenticated(Context.Session))
            {
                <a asp-controller="OrdenesTrabajo" asp-action="Index" class="btn btn-light">Mis ordenes</a>
            }
            @if (SessionAuthHelper.IsDriverAuthenticated(Context.Session))
            {
                <a asp-controller="Inspecciones" asp-action="Crear" class="btn btn-light">Nueva inspeccion</a>
                <a asp-controller="Incidencias" asp-action="Crear" class="btn btn-secondary">Nueva incidencia</a>
            }
        </div>
    </div>
    <div class="dashboard-hero__status">
        <div class="status-orb"></div>
        <span class="status-caption">Estado general</span>
        <strong>@health</strong>
        <small>@Model.VehiculosOperativos operativos, @Model.VehiculosEnMantenimiento en taller y @Model.VehiculosFueraDeServicio fuera de servicio.</small>
    </div>
</section>

<section class="metrics-grid">
    <article class="metric-card">
        <span>Flota registrada</span>
        <strong>@Model.TotalVehiculos</strong>
        <small>unidades dadas de alta</small>
    </article>
    <article class="metric-card accent-green">
        <span>Operativos</span>
        <strong>@Model.VehiculosOperativos</strong>
        <small>listos para circular</small>
    </article>
    <article class="metric-card accent-amber">
        <span>En mantenimiento</span>
        <strong>@Model.VehiculosEnMantenimiento</strong>
        <small>con ordenes activas</small>
    </article>
    <article class="metric-card accent-red">
        <span>Fuera de servicio</span>
        <strong>@Model.VehiculosFueraDeServicio</strong>
        <small>requieren atencion critica</small>
    </article>
    <article class="metric-card">
        <span>Inspecciones hoy</span>
        <strong>@Model.InspeccionesHoy</strong>
        <small>checklists de conductor</small>
    </article>
    <article class="metric-card">
        <span>Incidencias abiertas</span>
        <strong>@Model.IncidenciasAbiertas</strong>
        <small>eventos sin cierre</small>
    </article>
    <article class="metric-card">
        <span>Ordenes pendientes</span>
        <strong>@Model.OrdenesPendientes</strong>
        <small>por asignar o ejecutar</small>
    </article>
    <article class="metric-card">
        <span>Cerradas este mes</span>
        <strong>@Model.OrdenesFinalizadasMes</strong>
        <small>mantenimientos completados</small>
    </article>
</section>

<section class="content-grid">
    <div class="stack">
        <div class="table-card board-card">
            <div class="section-head">
                <div>
                    <span class="section-kicker">Mapa de fallas</span>
                    <h3>Incidencias por tipo</h3>
                </div>
            </div>
            <div class="mini-list">
                @foreach (var item in Model.IncidenciasPorTipo)
                {
                    <div class="mini-item">
                        <div>
                            <strong>@item.Label</strong>
                            <small>casos acumulados en el periodo visible</small>
                        </div>
                        <strong>@item.Value</strong>
                    </div>
                }
            </div>
        </div>
        <div class="table-card board-card">
            <div class="section-head">
                <div>
                    <span class="section-kicker">Carga del taller</span>
                    <h3>Ordenes por estado</h3>
                </div>
            </div>
            <div class="mini-list">
                @foreach (var item in Model.OrdenesPorEstado)
                {
                    <div class="mini-item">
                        <div>
                            <strong>@item.Label</strong>
                            <small>situacion actual de la orden</small>
                        </div>
                        <strong>@item.Value</strong>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="stack">
        <div class="table-card board-card board-card--highlight">
            <div class="section-head">
                <div>
                    <span class="section-kicker">Programacion</span>
                    <h3>Preventivos proximos</h3>
                </div>
            </div>
            <div class="mini-list">
                @foreach (var item in Model.ProximosPreventivos)
                {
                    <div class="mini-item">
                        <div>
                            <strong>@item.Vehiculo</strong>
                            <small>@item.Actividades</small>
                        </div>
                        <div>
                            <span class="chip @(item.Prioridad == "ALTA" ? "warn" : "")">@item.Prioridad</span>
                            <small>@item.ProximaFechaProgramada.ToString("dd/MM/yyyy")</small>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="table-card board-card">
            <div class="section-head">
                <div>
                    <span class="section-kicker">Cadencia</span>
                    <h3>Tendencia mensual</h3>
                </div>
            </div>
            <div class="timeline-list">
                @foreach (var item in Model.HistorialMensual)
                {
                    <div class="timeline-row">
                        <div class="timeline-meta">
                            <strong>@item.Label</strong>
                            <small>@item.Value ordenes registradas</small>
                        </div>
                        <div class="timeline-bar">
                            <span style="width:@Math.Min(100, Math.Max(8, item.Value * 12))%"></span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
