@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "BitÃ¡cora de Trazabilidad Operacional";
}

<div class="page-shell">
    <!-- Header -->
    <div style="margin-bottom: 2rem;">
        <h1 style="font-size: 2rem; font-weight: 800; background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
            <i class="fa-solid fa-clock-rotate-left"></i> BitÃ¡cora de Trazabilidad Operacional
        </h1>
        <p style="color: var(--text-secondary); font-size: 0.95rem; margin-top: 0.25rem;">
            Historial detallado de todas las modificaciones de base de datos capturadas automÃ¡ticamente por el interceptor EF Core.
        </p>
    </div>

    <!-- Filter Panel -->
    <div class="glass-card" style="padding: 1.5rem; margin-bottom: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
        <h3 style="font-size: 1rem; font-weight: 600; color: white; display: flex; align-items: center; gap: 0.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
            <i class="fa-solid fa-filter"></i> Filtros de BÃºsqueda
        </h3>
        <div class="form-grid-auto">
            <div>
                <label class="form-label">Tabla Afectada</label>
                <input type="text" id="filter-table" class="custom-input" placeholder="Ej: VEHICULOS" />
            </div>
            <div>
                <label class="form-label">AcciÃ³n</label>
                <select id="filter-action" class="custom-input">
                    <option value="">Todas las acciones</option>
                    <option value="INSERT">INSERT (Crear)</option>
                    <option value="UPDATE">UPDATE (Actualizar)</option>
                    <option value="DELETE">DELETE (Borrar)</option>
                </select>
            </div>
            <div>
                <label class="form-label">Desde</label>
                <input type="date" id="filter-from" class="custom-input" />
            </div>
            <div>
                <label class="form-label">Hasta</label>
                <input type="date" id="filter-to" class="custom-input" />
            </div>
        </div>
        <div class="panel-actions panel-actions-end" style="margin-top: 0.5rem;">
            <button onclick="clearFilters()" class="custom-input" style="width: auto; padding: 0.5rem 1.5rem; background: rgba(255,255,255,0.05); color: white; cursor: pointer; border-radius: 8px;">
                Limpiar
            </button>
            <button onclick="fetchAuditLogs()" class="btn-primary" style="border-radius: 8px; padding: 0.5rem 2rem;">
                <i class="fa-solid fa-search"></i> Buscar
            </button>
        </div>
    </div>

    <!-- Table Container -->
    <div class="glass-card responsive-table-card">
        <table id="audit-table">
            <thead>
                <tr style="border-bottom: 2px solid var(--border-color); color: var(--text-secondary); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">
                    <th style="padding: 1rem;">Fecha</th>
                    <th style="padding: 1rem;">Usuario Responsable</th>
                    <th style="padding: 1rem;">AcciÃ³n</th>
                    <th style="padding: 1rem;">Tabla Afectada</th>
                    <th style="padding: 1rem; text-align: right;">Detalle de Cambios</th>
                </tr>
            </thead>
            <tbody id="audit-list">
                <!-- Rendered dynamically -->
                <tr>
                    <td colspan="5" style="text-align: center; padding: 3rem; color: var(--text-muted);">
                        Realice una bÃºsqueda para cargar registros.
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Details Modal -->
<div id="audit-detail-modal" class="modal-overlay">
    <div class="glass-card modal-card modal-card-lg">
        <div class="modal-header">
            <h3 style="font-size: 1.3rem; font-weight: 700; color: white;">
                <i class="fa-solid fa-magnifying-glass-chart"></i> Detalle de Cambios en Base de Datos
            </h3>
            <button onclick="closeDetailModal()" style="background: none; border: none; color: var(--text-secondary); cursor: pointer; font-size: 1.25rem;">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="audit-detail-grid">
            <div><strong>Usuario:</strong> <span id="detail-user" style="color: var(--primary);">SYSTEM</span></div>
            <div><strong>AcciÃ³n:</strong> <span id="detail-action" class="action-badge">UPDATE</span></div>
            <div><strong>Tabla Afectada:</strong> <span id="detail-table" style="color: var(--secondary);">VEHICULOS</span></div>
        </div>

        <div id="diff-container" style="overflow-y: auto; flex: 1; min-height: 250px; background: rgba(0,0,0,0.2); border-radius: 10px; border: 1px solid var(--border-color); padding: 1rem;">
            <!-- Comparison table goes here -->
        </div>

        <div class="modal-actions">
            <button onclick="closeDetailModal()" class="btn-primary" style="border-radius: 8px; padding: 0.6rem 2rem;">
                Cerrar
            </button>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .modal-overlay.active {
            animation: fadeIn 0.2s ease-out;
        }
        @@keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        #audit-table tbody tr {
            border-bottom: 1px solid var(--border-color);
            transition: background 0.2s;
        }
        #audit-table tbody tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }
        .action-badge {
            padding: 0.25rem 0.6rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
            text-transform: uppercase;
        }
        .action-insert {
            background: rgba(16, 185, 129, 0.15);
            color: var(--success);
            border: 1px solid rgba(16, 185, 129, 0.3);
        }
        .action-update {
            background: rgba(245, 158, 11, 0.15);
            color: var(--warning);
            border: 1px solid rgba(245, 158, 11, 0.3);
        }
        .action-delete {
            background: rgba(239, 68, 68, 0.15);
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.3);
        }
        .btn-detail-view {
            background: rgba(6, 182, 212, 0.1);
            color: var(--primary);
            border: 1px solid rgba(6, 182, 212, 0.2);
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-detail-view:hover {
            background: var(--primary);
            color: white;
            box-shadow: 0 0 10px var(--primary-glow);
        }
    </style>
}

@section Scripts {
    <script>
        const apiBaseUrl = '@(Configuration["ApiSettings:BrowserBaseUrl"] ?? Configuration["ApiSettings:BaseUrl"])';
        const token = '@Context.Session.GetString("Token")';

        let auditLogs = [];

        // Set default dates
        document.getElementById('filter-from').valueAsDate = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000); // 7 days ago
        document.getElementById('filter-to').valueAsDate = new Date();

        async function fetchAuditLogs() {
            const table = document.getElementById('filter-table').value.trim();
            const action = document.getElementById('filter-action').value;
            const from = document.getElementById('filter-from').value;
            const to = document.getElementById('filter-to').value;

            const tbody = document.getElementById('audit-list');
            tbody.innerHTML = `
                <tr>
                    <td colspan="5" style="text-align: center; padding: 3rem; color: var(--text-muted);">
                        <i class="fa-solid fa-spinner fa-spin" style="font-size: 1.5rem; margin-bottom: 0.5rem; display: block;"></i> Buscando registros en base de datos...
                    </td>
                </tr>
            `;

            let url = `${apiBaseUrl}auditoria?`;
            if (table) url += `tabla=${encodeURIComponent(table)}&`;
            if (action) url += `accion=${encodeURIComponent(action)}&`;
            if (from) url += `desde=${encodeURIComponent(from)}&`;
            if (to) url += `hasta=${encodeURIComponent(to)}&`;

            try {
                const res = await fetch(url, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (res.ok) {
                    auditLogs = await res.json();
                    renderTable(auditLogs);
                } else {
                    tbody.innerHTML = `<tr><td colspan="5" style="text-align:center; padding:2rem; color:var(--danger);">Error al consultar bitÃ¡cora (${res.status}).</td></tr>`;
                }
            } catch (err) {
                console.error(err);
                tbody.innerHTML = `<tr><td colspan="5" style="text-align:center; padding:2rem; color:var(--danger);">Falla de conexiÃ³n con el servidor.</td></tr>`;
            }
        }

        function renderTable(list) {
            const tbody = document.getElementById('audit-list');
            if (list.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" style="text-align:center; padding:3rem; color:var(--text-muted);">No se encontraron registros de auditorÃ­a en este rango.</td></tr>`;
                return;
            }

            tbody.innerHTML = '';
            list.forEach(a => {
                const date = new Date(a.fecha).toLocaleString('es-PE');
                const actionClass = a.accion === 'INSERT' ? 'action-insert' : (a.accion === 'UPDATE' ? 'action-update' : 'action-delete');
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td style="padding:1rem; font-family:monospace; color:var(--text-secondary);">${date}</td>
                    <td style="padding:1rem; font-weight:600;"><i class="fa-solid fa-user-circle" style="color:var(--primary); margin-right:4px;"></i> ${a.usuario}</td>
                    <td style="padding:1rem;"><span class="action-badge ${actionClass}">${a.accion}</span></td>
                    <td style="padding:1rem; font-weight:600; color:var(--secondary); font-family:monospace;">${a.tablaAfectada}</td>
                    <td style="padding:1rem; text-align:right;">
                        <button onclick="showDetails(${a.idAuditoria})" class="btn-detail-view"><i class="fa-solid fa-eye"></i> Detalle de cambios</button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function clearFilters() {
            document.getElementById('filter-table').value = '';
            document.getElementById('filter-action').value = '';
            document.getElementById('filter-from').valueAsDate = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000);
            document.getElementById('filter-to').valueAsDate = new Date();
            fetchAuditLogs();
        }

        function showDetails(id) {
            const log = auditLogs.find(item => item.idAuditoria === id);
            if (!log) return;

            document.getElementById('detail-user').textContent = log.usuario;
            document.getElementById('detail-table').textContent = log.tablaAfectada;
            
            const badge = document.getElementById('detail-action');
            badge.textContent = log.accion;
            badge.className = `action-badge ${log.accion === 'INSERT' ? 'action-insert' : (log.accion === 'UPDATE' ? 'action-update' : 'action-delete')}`;

            const container = document.getElementById('diff-container');
            container.innerHTML = renderDiff(log.datosAnteriores, log.datosNuevos);

            document.getElementById('audit-detail-modal').classList.add('active');
        }

        function closeDetailModal() {
            document.getElementById('audit-detail-modal').classList.remove('active');
        }

        function renderDiff(oldJson, newJson) {
            let oldObj = {};
            let newObj = {};
            
            try {
                if (oldJson) oldObj = JSON.parse(oldJson);
            } catch(e) { console.error("Error parsing oldJson", e); }
            
            try {
                if (newJson) newObj = JSON.parse(newJson);
            } catch(e) { console.error("Error parsing newJson", e); }
            
            const allKeys = new Set([...Object.keys(oldObj), ...Object.keys(newObj)]);
            
            if (allKeys.size === 0) {
                return `<p style="color:var(--text-muted); text-align:center; padding:2rem;">Sin datos para mostrar en este registro.</p>`;
            }

            let html = `
                <table style="width:100%; border-collapse:collapse; text-align:left; font-size:0.85rem;">
                    <thead>
                        <tr style="border-bottom: 2px solid var(--border-color); color:var(--text-secondary); font-weight:600; font-family:'Outfit';">
                            <th style="padding:10px 8px;">Columna / Propiedad</th>
                            <th style="padding:10px 8px;">Valor Anterior (Previo)</th>
                            <th style="padding:10px 8px;">Valor Nuevo (Actualizado)</th>
                        </tr>
                    </thead>
                    <tbody>
            `;
                
            allKeys.forEach(key => {
                const oldVal = oldObj[key] !== undefined && oldObj[key] !== null ? oldObj[key] : '-';
                const newVal = newObj[key] !== undefined && newObj[key] !== null ? newObj[key] : '-';
                const isChanged = oldObj[key] !== newObj[key];
                
                const rowStyle = isChanged ? 'background: rgba(6, 182, 212, 0.03);' : '';
                const oldStyle = isChanged && oldJson ? 'color: var(--danger); text-decoration: line-through; opacity: 0.8;' : '';
                const newStyle = isChanged && newJson ? 'color: var(--success); font-weight:700;' : '';
                
                html += `
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05); ${rowStyle}">
                        <td style="padding:8px; font-weight:600; color:var(--primary); font-family:monospace;">${key}</td>
                        <td style="padding:8px; ${oldStyle}">${typeof oldVal === 'object' ? JSON.stringify(oldVal) : oldVal}</td>
                        <td style="padding:8px; ${newStyle}">${typeof newVal === 'object' ? JSON.stringify(newVal) : newVal}</td>
                    </tr>
                `;
            });
            
            html += '</tbody></table>';
            return html;
        }

        const auditDetailModal = document.getElementById('audit-detail-modal');
        auditDetailModal.addEventListener('click', (event) => {
            if (event.target === auditDetailModal) {
                closeDetailModal();
            }
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && auditDetailModal.classList.contains('active')) {
                closeDetailModal();
            }
        });

        // Init load
        fetchAuditLogs();
    </script>
}

