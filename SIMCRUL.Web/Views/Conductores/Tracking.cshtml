@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@using SIMCRUL.Web.Infrastructure
@{
    ViewData["Title"] = "Modo Conductor GPS";
    var isDriverSession = SessionAuthHelper.IsDriverAuthenticated(Context.Session);
    var canShareLocation = isDriverSession;
}

@if (!canShareLocation)
{
    <div class="driver-app">
        <section class="driver-hero">
            <div class="driver-hero-copy">
                <span class="driver-badge"><i class="fa-solid fa-location-arrow"></i> Acceso de conductor requerido</span>
                <h1>Comparte ubicacion del bus desde la web</h1>
                <p>
                    Inicia sesion con un usuario de conductor vinculado en mantenimiento para activar la ubicacion
                    en tiempo real desde tu telefono o navegador. El sistema tomara automaticamente tu ruta, tu bus
                    y tu asignacion operativa activa.
                </p>
            </div>
            <div class="driver-hero-actions">
                <a asp-controller="Home" asp-action="Login" class="btn-primary">
                    <i class="fa-solid fa-right-to-bracket"></i> Iniciar sesion como conductor
                </a>
            </div>
        </section>

        <section class="driver-grid" style="grid-template-columns: 1fr;">
            <div class="glass-card driver-panel" style="max-width: 720px; margin: 0 auto;">
                <div class="driver-panel-header">
                    <h2><i class="fa-solid fa-mobile-screen-button"></i> Modo esperado</h2>
                    <span class="driver-chip driver-chip-muted">Listo para GPS</span>
                </div>

                <div class="driver-note">
                    <i class="fa-solid fa-circle-info"></i>
                    Al iniciar sesion se habilitara el boton <strong style="margin-left:0.35rem;">Activar ubicacion en tiempo real</strong>
                    si tu usuario esta amarrado a un conductor con ruta y bus asignados.
                </div>

                <div class="driver-selection">
                    <div>
                        <span class="driver-label">Rol requerido</span>
                        <strong>Conductor</strong>
                    </div>
                    <div>
                        <span class="driver-label">Condicion</span>
                        <strong>Usuario vinculado a conductor</strong>
                    </div>
                    <div>
                        <span class="driver-label">Asignacion requerida</span>
                        <strong>Ruta + vehiculo activos</strong>
                    </div>
                    <div>
                        <span class="driver-label">Accion</span>
                        <strong>Compartir ubicacion GPS</strong>
                    </div>
                </div>
            </div>
        </section>
    </div>
}
else
{
    <div class="driver-app">
        <section class="driver-hero">
            <div class="driver-hero-copy">
                <span class="driver-badge"><i class="fa-solid fa-location-arrow"></i> GPS en vivo desde navegador</span>
                <h1>Modo Conductor</h1>
                <p>
                    Comparte la ubicacion del bus en tiempo real desde Chrome o el telefono. La plataforma seguira registrando
                    alertas de exceso de velocidad, desvio de ruta y eventos operativos.
                </p>
            </div>
            <div class="driver-hero-actions">
                <a asp-controller="Passenger" asp-action="Index" class="driver-link">
                    <i class="fa-solid fa-map"></i> Ver monitoreo publico
                </a>
                <a asp-controller="Home" asp-action="Logout" class="driver-link">
                    <i class="fa-solid fa-right-from-bracket"></i> Cerrar sesion
                </a>
            </div>
        </section>

        <section class="driver-grid">
            <div class="glass-card driver-panel">
                <div class="driver-panel-header">
                    <h2><i class="fa-solid fa-bus"></i> Unidad asignada</h2>
                    <span id="connection-chip" class="driver-chip">Esperando permiso GPS</span>
                </div>

                <div id="assignment-status" class="driver-note">
                    <i class="fa-solid fa-link"></i>
                    Tu cuenta de conductor debe estar vinculada a un conductor activo con una asignacion operativa vigente.
                </div>

                <div class="driver-selection" id="selection-summary">
                    <div>
                        <span class="driver-label">Conductor</span>
                        <strong id="summary-driver">Pendiente</strong>
                    </div>
                    <div>
                        <span class="driver-label">Ruta</span>
                        <strong id="summary-route">Pendiente</strong>
                    </div>
                    <div>
                        <span class="driver-label">Vehiculo</span>
                        <strong id="summary-vehicle">Pendiente</strong>
                    </div>
                    <div>
                        <span class="driver-label">Limite</span>
                        <strong id="summary-limit">Pendiente</strong>
                    </div>
                </div>

                <div class="driver-actions">
                    <button id="start-sharing" class="btn-primary">
                        <i class="fa-solid fa-location-crosshairs"></i> Activar ubicacion en tiempo real
                    </button>
                    <button id="stop-sharing" class="custom-input driver-stop" type="button">
                        <i class="fa-solid fa-hand"></i> Desactivar ubicacion
                    </button>
                </div>

                <div class="driver-note">
                    <i class="fa-solid fa-circle-info"></i>
                    En Android o iPhone, abre esta pagina con HTTPS, acepta el permiso de ubicacion y deja la pestana activa para mejor precision.
                    La ruta y el bus se toman de tu asignacion activa; aqui no necesitas seleccionar nada manualmente.
                </div>
            </div>

            <div class="glass-card driver-panel">
                <div class="driver-panel-header">
                    <h2><i class="fa-solid fa-wave-square"></i> Estado del envio</h2>
                    <span id="transmission-chip" class="driver-chip driver-chip-muted">0 lecturas</span>
                </div>

                <div class="driver-stats">
                    <div class="driver-stat-card">
                        <span>Velocidad actual</span>
                        <strong id="current-speed">0 km/h</strong>
                    </div>
                    <div class="driver-stat-card">
                        <span>Precision GPS</span>
                        <strong id="current-accuracy">-</strong>
                    </div>
                    <div class="driver-stat-card">
                        <span>Ultimo envio</span>
                        <strong id="last-sync">Pendiente</strong>
                    </div>
                    <div class="driver-stat-card">
                        <span>Estado local</span>
                        <strong id="local-mode">Normal</strong>
                    </div>
                </div>

                <div class="driver-log-wrap">
                    <div class="driver-log-header">
                        <h3>Bitacora local</h3>
                        <button type="button" class="driver-link-button" onclick="clearLogs()">Limpiar</button>
                    </div>
                    <div id="driver-log" class="driver-log"></div>
                </div>
            </div>
        </section>
    </div>
}

@section Styles {
    <style>
        .driver-app {
            min-height: 100vh;
            padding: 1.5rem;
            background:
                radial-gradient(circle at top left, rgba(6, 182, 212, 0.18), transparent 30%),
                radial-gradient(circle at bottom right, rgba(99, 102, 241, 0.16), transparent 28%),
                linear-gradient(180deg, #08111d 0%, #0b0f19 100%);
        }

        .driver-hero {
            max-width: 1200px;
            margin: 0 auto 1.25rem;
            padding: 1.4rem 1.5rem;
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 28px;
            background: rgba(8, 17, 29, 0.76);
            display: flex;
            justify-content: space-between;
            gap: 1.5rem;
            align-items: flex-end;
        }

        .driver-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 0.85rem;
            border-radius: 9999px;
            background: rgba(6, 182, 212, 0.12);
            border: 1px solid rgba(6, 182, 212, 0.2);
            color: var(--primary);
            font-size: 0.85rem;
            font-weight: 700;
            margin-bottom: 0.95rem;
        }

        .driver-hero-copy h1 {
            font-size: clamp(2rem, 6vw, 3.35rem);
            line-height: 1.05;
            margin-bottom: 0.75rem;
        }

        .driver-hero-copy p {
            max-width: 760px;
            color: var(--text-secondary);
            line-height: 1.65;
        }

        .driver-hero-actions {
            display: flex;
            gap: 0.85rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .driver-link,
        .driver-link-button {
            display: inline-flex;
            align-items: center;
            gap: 0.55rem;
            color: var(--primary);
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 0.8rem 1rem;
            border-radius: 14px;
            text-decoration: none;
            font-weight: 600;
        }

        .driver-link-button {
            cursor: pointer;
        }

        .driver-grid {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: minmax(320px, 420px) minmax(0, 1fr);
            gap: 1rem;
        }

        .driver-panel {
            padding: 1.3rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .driver-panel-header {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            align-items: center;
        }

        .driver-panel-header h2 {
            font-size: 1.05rem;
            font-weight: 700;
        }

        .driver-chip {
            padding: 0.4rem 0.7rem;
            border-radius: 9999px;
            font-size: 0.78rem;
            font-weight: 700;
            color: #6ee7b7;
            background: rgba(16, 185, 129, 0.13);
            border: 1px solid rgba(16, 185, 129, 0.25);
        }

        .driver-chip-muted {
            color: #93c5fd;
            background: rgba(59, 130, 246, 0.12);
            border-color: rgba(59, 130, 246, 0.24);
        }

        .driver-selection {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.9rem;
            padding: 1rem;
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
        }

        .driver-label {
            display: block;
            margin-bottom: 0.28rem;
            color: var(--text-muted);
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .driver-toggle-grid {
            display: grid;
            gap: 0.85rem;
        }

        .driver-toggle-card {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            align-items: center;
            padding: 0.95rem 1rem;
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
        }

        .driver-toggle-card input {
            width: 22px;
            height: 22px;
            accent-color: var(--primary);
            cursor: pointer;
        }

        .driver-toggle-copy {
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
        }

        .driver-toggle-copy small {
            color: var(--text-secondary);
            line-height: 1.45;
        }

        .driver-actions {
            display: flex;
            gap: 0.85rem;
        }

        .driver-actions > * {
            flex: 1;
            justify-content: center;
            text-align: center;
        }

        .driver-stop {
            color: white;
            background: rgba(239, 68, 68, 0.14);
            border-color: rgba(239, 68, 68, 0.28);
        }

        .driver-note {
            display: flex;
            gap: 0.7rem;
            align-items: flex-start;
            color: var(--text-secondary);
            font-size: 0.92rem;
            line-height: 1.55;
            padding: 0.95rem 1rem;
            border-radius: 18px;
            background: rgba(6, 182, 212, 0.08);
            border: 1px solid rgba(6, 182, 212, 0.16);
        }

        .driver-note.driver-note-danger {
            background: rgba(239, 68, 68, 0.1);
            border-color: rgba(239, 68, 68, 0.24);
            color: #fecaca;
        }

        .driver-note.driver-note-success {
            background: rgba(16, 185, 129, 0.1);
            border-color: rgba(16, 185, 129, 0.24);
            color: #bbf7d0;
        }

        .driver-stats {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.85rem;
        }

        .driver-stat-card {
            padding: 1rem;
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
        }

        .driver-stat-card span {
            color: var(--text-secondary);
            font-size: 0.82rem;
        }

        .driver-stat-card strong {
            font-size: 1.1rem;
        }

        .driver-log-wrap {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            min-height: 0;
            flex: 1;
        }

        .driver-log-header {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            align-items: center;
        }

        .driver-log-header h3 {
            font-size: 0.95rem;
        }

        .driver-log {
            min-height: 320px;
            max-height: 420px;
            overflow-y: auto;
            padding: 0.75rem;
            border-radius: 18px;
            background: #08111d;
            border: 1px solid rgba(255, 255, 255, 0.06);
            font-family: Consolas, monospace;
            font-size: 0.82rem;
            line-height: 1.6;
        }

        .driver-log-entry {
            padding: 0.5rem 0.6rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            color: #dbeafe;
        }

        .driver-log-entry strong {
            color: white;
        }

        .driver-log-entry.error {
            color: #fca5a5;
        }

        @@media (max-width: 900px) {
            .driver-grid {
                grid-template-columns: 1fr;
            }

            .driver-hero {
                flex-direction: column;
                align-items: stretch;
            }

            .driver-hero-actions {
                justify-content: stretch;
            }
        }

        @@media (max-width: 640px) {
            .driver-app {
                padding: 1rem;
            }

            .driver-hero,
            .driver-panel {
                padding: 1rem;
                border-radius: 22px;
            }

            .driver-selection,
            .driver-stats {
                grid-template-columns: 1fr;
            }

            .driver-actions {
                flex-direction: column;
            }
        }
    </style>
}

@section Scripts {
    <script>
        const canShareLocation = @canShareLocation.ToString().ToLowerInvariant();

        function clearLogs() {
            const logContainer = document.getElementById('driver-log');
            if (!logContainer) {
                return;
            }

            logContainer.innerHTML = '<div class="driver-log-entry"><strong>Bitacora limpiada.</strong> Sigue registrando nuevos eventos.</div>';
        }

        if (canShareLocation) {
            const apiBaseUrl = '@(Configuration["ApiSettings:BrowserBaseUrl"] ?? Configuration["ApiSettings:BaseUrl"])';
            const token = '@Context.Session.GetString("Token")';
            const assignmentStatus = document.getElementById('assignment-status');
            const startButton = document.getElementById('start-sharing');
            const stopButton = document.getElementById('stop-sharing');
            const connectionChip = document.getElementById('connection-chip');
            const transmissionChip = document.getElementById('transmission-chip');
            const currentSpeed = document.getElementById('current-speed');
            const currentAccuracy = document.getElementById('current-accuracy');
            const lastSync = document.getElementById('last-sync');
            const localMode = document.getElementById('local-mode');
            const logContainer = document.getElementById('driver-log');

            const state = {
                assignment: null,
                watchId: null,
                lastPosition: null,
                lastSentAt: 0,
                sentCount: 0
            };

            async function initDriverApp() {
                renderPlaceholder();

                try {
                    const response = await fetch(`${apiBaseUrl}gps/driver-options`, {
                        headers: {
                            'Authorization': `Bearer ${token}`
                        }
                    });

                    if (!response.ok) {
                        const errorBody = await readErrorResponse(response);
                        throw new Error(errorBody || `No se pudieron cargar las unidades activas (${response.status}).`);
                    }

                    const assignments = await response.json();
                    state.assignment = Array.isArray(assignments) && assignments.length ? assignments[0] : null;
                    updateSelectionSummary();
                    updateAssignmentStatus();

                    if (!state.assignment) {
                        connectionChip.textContent = 'Sin asignacion';
                        addLog('Sistema', 'Tu usuario conductor no tiene una asignacion activa con GPS disponible.', true);
                        return;
                    }

                    addLog('Sistema', `Unidad ${state.assignment.placa} lista para compartir ubicacion.`);
                } catch (error) {
                    addLog('Error', error.message, true);
                    connectionChip.textContent = 'Sin asignaciones';
                    assignmentStatus.classList.add('driver-note-danger');
                    assignmentStatus.innerHTML = `<i class="fa-solid fa-triangle-exclamation"></i> ${escapeHtml(error.message)}`;
                }
            }

            function renderPlaceholder() {
                logContainer.innerHTML = '<div class="driver-log-entry"><strong>Listo.</strong> Esperando configuracion del conductor.</div>';
                updateSelectionSummary();
                updateAssignmentStatus();
            }

            function getSelectedAssignment() {
                return state.assignment;
            }

            function updateSelectionSummary() {
                const selected = getSelectedAssignment();

                document.getElementById('summary-driver').textContent = selected ? selected.conductor : 'Pendiente';
                document.getElementById('summary-route').textContent = selected ? selected.ruta : 'Pendiente';
                document.getElementById('summary-vehicle').textContent = selected ? `${selected.placa} / ${selected.codigoVehiculo}` : 'Pendiente';
                document.getElementById('summary-limit').textContent = selected ? `${Number(selected.velocidadMaximaKmh).toFixed(0)} km/h` : 'Pendiente';
            }

            function updateAssignmentStatus() {
                const selected = getSelectedAssignment();
                assignmentStatus.classList.remove('driver-note-danger', 'driver-note-success');

                if (!selected) {
                    assignmentStatus.classList.add('driver-note-danger');
                    assignmentStatus.innerHTML = '<i class="fa-solid fa-link-slash"></i> Tu usuario conductor no tiene un conductor vinculado con bus, ruta y GPS activos.';
                    return;
                }

                assignmentStatus.classList.add('driver-note-success');
                assignmentStatus.innerHTML = `<i class="fa-solid fa-circle-check"></i> Asignacion detectada: ${escapeHtml(selected.ruta)} en ${escapeHtml(selected.placa)}. Solo falta activar tu GPS.`;
            }

            function addLog(title, message, isError = false) {
                const entry = document.createElement('div');
                entry.className = `driver-log-entry${isError ? ' error' : ''}`;
                entry.innerHTML = `<strong>${escapeHtml(title)}:</strong> ${escapeHtml(message)}`;
                logContainer.prepend(entry);
            }

            function updateModeLabel() {
                localMode.textContent = 'GPS real';
            }

            function setSharingState(isSharing) {
                startButton.disabled = isSharing || !getSelectedAssignment();
                stopButton.disabled = !isSharing;
                connectionChip.textContent = isSharing
                    ? 'GPS compartiendo'
                    : (getSelectedAssignment() ? 'Listo para activar' : 'Sin asignacion');
            }

            function startSharing() {
                const selected = getSelectedAssignment();
                if (!selected) {
                    alert('Tu usuario conductor no tiene una unidad activa asignada.');
                    return;
                }

                if (!navigator.geolocation) {
                    addLog('Error', 'Este navegador no soporta geolocalizacion.', true);
                    return;
                }

                if (state.watchId !== null) {
                    addLog('Sistema', 'La ubicacion ya esta activa.');
                    return;
                }

                state.watchId = navigator.geolocation.watchPosition(onPositionReceived, onPositionError, {
                    enableHighAccuracy: true,
                    maximumAge: 3000,
                    timeout: 15000
                });

                setSharingState(true);
                addLog('GPS', `Ubicacion activada para ${selected.placa}.`);
            }

            function stopSharing() {
                if (state.watchId !== null) {
                    navigator.geolocation.clearWatch(state.watchId);
                    state.watchId = null;
                }

                state.lastPosition = null;
                setSharingState(false);
                addLog('GPS', 'La ubicacion en tiempo real fue desactivada.');
            }

            async function onPositionReceived(position) {
                const selected = getSelectedAssignment();
                if (!selected) {
                    stopSharing();
                    return;
                }

                const now = Date.now();
                if (now - state.lastSentAt < 2500) {
                    return;
                }

                state.lastSentAt = now;

                const rawSpeedKmh = calculateSpeed(position);
                const payload = buildTelemetryPayload(selected, position, rawSpeedKmh);

                currentSpeed.textContent = `${payload.velocidadKmh.toFixed(1)} km/h`;
                currentAccuracy.textContent = position.coords.accuracy ? `${Math.round(position.coords.accuracy)} m` : '-';
                updateModeLabel();

                try {
                    const response = await fetch(`${apiBaseUrl}gps/telemetry`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    const responseText = await response.text();
                    if (!response.ok) {
                        throw new Error(responseText || `Error ${response.status}`);
                    }

                    state.sentCount += 1;
                    transmissionChip.textContent = `${state.sentCount} lecturas`;
                    lastSync.textContent = new Date().toLocaleTimeString('es-PE');
                    addLog('Telemetria', `${selected.placa} enviada a ${payload.velocidadKmh.toFixed(1)} km/h.`);
                } catch (error) {
                    addLog('Error', `No se pudo enviar la lectura: ${error.message}`, true);
                }
            }

            function onPositionError(error) {
                addLog('GPS', `No se pudo obtener la ubicacion (${error.code}). ${error.message}`, true);
                connectionChip.textContent = 'Permiso denegado o GPS sin senal';
            }

            function calculateSpeed(position) {
                if (typeof position.coords.speed === 'number' && position.coords.speed >= 0) {
                    state.lastPosition = position;
                    return position.coords.speed * 3.6;
                }

                if (!state.lastPosition) {
                    state.lastPosition = position;
                    return 0;
                }

                const distanceMeters = haversineMeters(
                    state.lastPosition.coords.latitude,
                    state.lastPosition.coords.longitude,
                    position.coords.latitude,
                    position.coords.longitude
                );

                const elapsedSeconds = Math.max(1, (position.timestamp - state.lastPosition.timestamp) / 1000);
                state.lastPosition = position;
                return (distanceMeters / elapsedSeconds) * 3.6;
            }

            function buildTelemetryPayload(selected, position, rawSpeedKmh) {
                const heading = typeof position.coords.heading === 'number' && !Number.isNaN(position.coords.heading)
                    ? position.coords.heading
                    : null;

                return {
                    imei: selected.imei,
                    latitud: position.coords.latitude,
                    longitud: position.coords.longitude,
                    velocidadKmh: Number(Math.max(0, rawSpeedKmh).toFixed(2)),
                    rumboGrados: heading,
                    precisionMetros: position.coords.accuracy || null,
                    eventoForzado: null
                };
            }

            async function readErrorResponse(response) {
                try {
                    const payload = await response.json();
                    return payload?.message || payload?.details || null;
                } catch {
                    return await response.text();
                }
            }

            function haversineMeters(lat1, lon1, lat2, lon2) {
                const earthRadius = 6371000;
                const dLat = toRadians(lat2 - lat1);
                const dLon = toRadians(lon2 - lon1);
                const a =
                    Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                    Math.cos(toRadians(lat1)) * Math.cos(toRadians(lat2)) *
                    Math.sin(dLon / 2) * Math.sin(dLon / 2);

                const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
                return earthRadius * c;
            }

            function toRadians(value) {
                return (value * Math.PI) / 180;
            }

            function escapeHtml(value) {
                return (value ?? '')
                    .toString()
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#39;');
            }

            startButton.addEventListener('click', startSharing);
            stopButton.addEventListener('click', stopSharing);

            setSharingState(false);
            updateModeLabel();
            initDriverApp();
        }
    </script>
}

