@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Mantenimiento de Conductores";
}

<div style="max-width: 1200px; margin: 2rem auto; padding: 0 1.5rem;">
    <!-- Header Actions -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 style="font-size: 2rem; font-weight: 800; background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                <i class="fa-solid fa-id-card"></i> Mantenimiento de Conductores
            </h1>
            <p style="color: var(--text-secondary); font-size: 0.95rem; margin-top: 0.25rem;">
                Gestione los conductores asignados a la operación de la flota.
            </p>
        </div>
        <button onclick="openModal()" class="btn-primary">
            <i class="fa-solid fa-plus"></i> Agregar Conductor
        </button>
    </div>

    <!-- Filter Bar -->
    <div class="glass-card" style="padding: 1rem; margin-bottom: 1.5rem; display: flex; gap: 1rem; align-items: center;">
        <div style="flex: 1; position: relative;">
            <input type="text" id="search-input" onkeyup="filterTable()" class="custom-input" placeholder="Buscar por nombres, apellidos o DNI..." style="padding-left: 2.5rem;" />
            <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
        </div>
        <div style="display: flex; align-items: center; gap: 0.5rem;">
            <label class="form-label" style="margin-bottom: 0; white-space: nowrap;">Mostrar inactivos</label>
            <input type="checkbox" id="show-deleted" onchange="fetchDrivers()" style="width: 18px; height: 18px; cursor: pointer; accent-color: var(--primary);" />
        </div>
    </div>

    <!-- Table Container -->
    <div class="glass-card" style="overflow-x: auto; padding: 1rem;">
        <table id="drivers-table" style="width: 100%; border-collapse: collapse; text-align: left;">
            <thead>
                <tr style="border-bottom: 2px solid var(--border-color); color: var(--text-secondary); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">
                    <th style="padding: 1rem;">Nombre Completo</th>
                    <th style="padding: 1rem;">DNI</th>
                    <th style="padding: 1rem;">Licencia</th>
                    <th style="padding: 1rem; text-align: center;">Categoría</th>
                    <th style="padding: 1rem; text-align: center;">Vence Licencia</th>
                    <th style="padding: 1rem; text-align: center;">Teléfono</th>
                    <th style="padding: 1rem; text-align: center;">Estado</th>
                    <th style="padding: 1rem; text-align: right;">Acciones</th>
                </tr>
            </thead>
            <tbody id="drivers-list">
                <!-- Rendered dynamically -->
                <tr>
                    <td colspan="8" style="text-align: center; padding: 3rem; color: var(--text-muted);">
                        <i class="fa-solid fa-spinner fa-spin" style="font-size: 1.5rem; margin-bottom: 0.5rem; display: block;"></i> Cargando conductores...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Add/Edit Modal -->
<div id="driver-modal" class="modal-overlay">
    <div class="glass-card" style="width: 100%; max-width: 600px; padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem;">
            <h3 id="modal-title" style="font-size: 1.3rem; font-weight: 700; color: white;">
                <i class="fa-solid fa-id-card"></i> Agregar Conductor
            </h3>
            <button onclick="closeModal()" style="background: none; border: none; color: var(--text-secondary); cursor: pointer; font-size: 1.25rem;">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <form id="driver-form" onsubmit="saveDriver(event)" style="display: flex; flex-direction: column; gap: 1.25rem;">
            <input type="hidden" id="driver-id" name="idConductor" value="0" />

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                    <label class="form-label">Nombres *</label>
                    <input type="text" id="nombres" name="nombres" class="custom-input" placeholder="Ej: Carlos Daniel" required />
                </div>
                <div>
                    <label class="form-label">Apellidos *</label>
                    <input type="text" id="apellidos" name="apellidos" class="custom-input" placeholder="Ej: Mendoza Flores" required />
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                    <label class="form-label">DNI *</label>
                    <input type="text" id="dni" name="dni" class="custom-input" max-length="8" placeholder="Ej: 72849284" required />
                </div>
                <div>
                    <label class="form-label">Teléfono</label>
                    <input type="text" id="telefono" name="telefono" class="custom-input" placeholder="Ej: 988776655" />
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 1rem;">
                <div>
                    <label class="form-label">Número de Licencia *</label>
                    <input type="text" id="num-licencia" name="numeroLicencia" class="custom-input" placeholder="Ej: Q72849284" required />
                </div>
                <div>
                    <label class="form-label">Categoría Licencia *</label>
                    <input type="text" id="cat-licencia" name="categoriaLicencia" class="custom-input" placeholder="Ej: A-IIIa" required />
                </div>
            </div>

            <div>
                <label class="form-label">Fecha Vencimiento Licencia *</label>
                <input type="date" id="vence-licencia" name="fechaVencimientoLicencia" class="custom-input" required />
            </div>

            <div id="estado-container" style="display: none; align-items: center; gap: 0.5rem;">
                <input type="checkbox" id="estado" name="estado" style="width: 18px; height: 18px; cursor: pointer; accent-color: var(--primary);" checked />
                <label class="form-label" style="margin-bottom: 0; cursor: pointer;" for="estado">Conductor Activo</label>
            </div>

            <div style="display: flex; gap: 1rem; justify-content: flex-end; border-top: 1px solid var(--border-color); padding-top: 1rem; margin-top: 0.5rem;">
                <button type="button" onclick="closeModal()" class="custom-input" style="width: auto; padding: 0.6rem 1.5rem; background: rgba(255,255,255,0.05); color: white; cursor: pointer; border-radius: 8px;">
                    Cancelar
                </button>
                <button type="submit" class="btn-primary" style="border-radius: 8px; padding: 0.6rem 2rem;">
                    Guardar
                </button>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <style>
        #drivers-table tbody tr {
            border-bottom: 1px solid var(--border-color);
            transition: background 0.2s;
        }
        #drivers-table tbody tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }
        .status-badge {
            padding: 0.25rem 0.6rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
        }
        .status-active {
            background: rgba(16, 185, 129, 0.15);
            color: var(--success);
            border: 1px solid rgba(16, 185, 129, 0.3);
        }
        .status-inactive {
            background: rgba(239, 68, 68, 0.15);
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.3);
        }
        .btn-action {
            background: none;
            border: none;
            cursor: pointer;
            padding: 0.25rem 0.5rem;
            border-radius: 6px;
            font-size: 0.9rem;
            transition: all 0.2s;
        }
        .btn-edit {
            color: var(--primary);
        }
        .btn-edit:hover {
            background: rgba(6, 182, 212, 0.1);
        }
        .btn-delete {
            color: var(--danger);
        }
        .btn-delete:hover {
            background: rgba(239, 68, 68, 0.1);
        }
    </style>
}

@section Scripts {
    <script>
        const apiBaseUrl = '@Configuration["ApiSettings:BaseUrl"]';
        const token = '@Context.Session.GetString("Token")';

        let allDrivers = [];

        async function fetchDrivers() {
            const showDeleted = document.getElementById('show-deleted').checked;
            const tbody = document.getElementById('drivers-list');
            
            try {
                const res = await fetch(`${apiBaseUrl}conductores?includeDeleted=${showDeleted}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                
                if (res.ok) {
                    allDrivers = await res.json();
                    renderTable(allDrivers);
                } else {
                    tbody.innerHTML = `<tr><td colspan="8" style="text-align:center; padding:2rem; color:var(--danger);">Error al cargar conductores (${res.status}).</td></tr>`;
                }
            } catch (err) {
                console.error(err);
                tbody.innerHTML = `<tr><td colspan="8" style="text-align:center; padding:2rem; color:var(--danger);">Falla de conexión con la API.</td></tr>`;
            }
        }

        function renderTable(list) {
            const tbody = document.getElementById('drivers-list');
            if (list.length === 0) {
                tbody.innerHTML = `<tr><td colspan="8" style="text-align:center; padding:3rem; color:var(--text-muted);">No se encontraron conductores.</td></tr>`;
                return;
            }

            tbody.innerHTML = '';
            list.forEach(c => {
                const venceDate = new Date(c.fechaVencimientoLicencia).toLocaleDateString('es-PE');
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td style="padding:1rem; font-weight:700;">${c.nombres} ${c.apellidos}</td>
                    <td style="padding:1rem;">${c.dni}</td>
                    <td style="padding:1rem; font-family:monospace; color:var(--text-secondary);">${c.numeroLicencia}</td>
                    <td style="padding:1rem; text-align:center;"><span style="font-size:0.85rem; background:rgba(255,255,255,0.05); padding:2px 8px; border-radius:4px;">${c.categoriaLicencia}</span></td>
                    <td style="padding:1rem; text-align:center;">${venceDate}</td>
                    <td style="padding:1rem; text-align:center;">${c.telefono || '-'}</td>
                    <td style="padding:1rem; text-align:center;">
                        <span class="status-badge ${c.estado ? 'status-active' : 'status-inactive'}">
                            ${c.estado ? 'Activo' : 'Inactivo'}
                        </span>
                    </td>
                    <td style="padding:1rem; text-align:right;">
                        <button onclick="editDriver(${c.idConductor})" class="btn-action btn-edit" title="Editar"><i class="fa-solid fa-pen-to-square"></i></button>
                        ${c.estado ? `<button onclick="deleteDriver(${c.idConductor})" class="btn-action btn-delete" title="Desactivar"><i class="fa-solid fa-trash"></i></button>` : ''}
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function filterTable() {
            const query = document.getElementById('search-input').value.toLowerCase().trim();
            if (!query) {
                renderTable(allDrivers);
                return;
            }

            const filtered = allDrivers.filter(c => 
                c.nombres.toLowerCase().includes(query) || 
                c.apellidos.toLowerCase().includes(query) || 
                c.dni.includes(query) || 
                c.numeroLicencia.toLowerCase().includes(query)
            );
            renderTable(filtered);
        }

        function openModal(isEdit = false) {
            const modal = document.getElementById('driver-modal');
            modal.classList.add('active');
            document.getElementById('estado-container').style.display = isEdit ? 'flex' : 'none';
            if (!isEdit) {
                document.getElementById('modal-title').innerHTML = '<i class="fa-solid fa-id-card"></i> Agregar Conductor';
                document.getElementById('driver-form').reset();
                document.getElementById('driver-id').value = "0";
            }
        }

        function closeModal() {
            document.getElementById('driver-modal').classList.remove('active');
        }

        async function editDriver(id) {
            const c = allDrivers.find(item => item.idConductor === id);
            if (!c) return;

            document.getElementById('modal-title').innerHTML = '<i class="fa-solid fa-id-card"></i> Editar Conductor';
            document.getElementById('driver-id').value = c.idConductor;
            document.getElementById('nombres').value = c.nombres;
            document.getElementById('apellidos').value = c.apellidos;
            document.getElementById('dni').value = c.dni;
            document.getElementById('telefono').value = c.telefono || '';
            document.getElementById('num-licencia').value = c.numeroLicencia;
            document.getElementById('cat-licencia').value = c.categoriaLicencia;
            
            // Format date for HTML input type="date" (YYYY-MM-DD)
            const d = new Date(c.fechaVencimientoLicencia);
            const formattedDate = d.toISOString().split('T')[0];
            document.getElementById('vence-licencia').value = formattedDate;
            document.getElementById('estado').checked = c.estado;

            openModal(true);
        }

        async function saveDriver(e) {
            e.preventDefault();
            const id = parseInt(document.getElementById('driver-id').value);
            
            const payload = {
                idConductor: id,
                nombres: document.getElementById('nombres').value,
                apellidos: document.getElementById('apellidos').value,
                dni: document.getElementById('dni').value,
                telefono: document.getElementById('telefono').value || null,
                numeroLicencia: document.getElementById('num-licencia').value,
                categoriaLicencia: document.getElementById('cat-licencia').value,
                fechaVencimientoLicencia: new Date(document.getElementById('vence-licencia').value).toISOString(),
                estado: id === 0 ? true : document.getElementById('estado').checked
            };

            const method = id === 0 ? 'POST' : 'PUT';
            const url = id === 0 ? `${apiBaseUrl}conductores` : `${apiBaseUrl}conductores/${id}`;

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                if (res.ok) {
                    closeModal();
                    fetchDrivers();
                } else {
                    const err = await res.json();
                    alert(`Error al guardar: ${err.message || 'Intente nuevamente'}`);
                }
            } catch (err) {
                alert("Falla de conexión.");
            }
        }

        async function deleteDriver(id) {
            if (!confirm("¿Está seguro que desea desactivar (Soft Delete) este conductor?")) return;

            try {
                const res = await fetch(`${apiBaseUrl}conductores/${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (res.ok) {
                    fetchDrivers();
                } else {
                    alert("Error al desactivar el conductor.");
                }
            } catch (err) {
                alert("Falla de conexión.");
            }
        }

        // Init load
        fetchDrivers();
    </script>
}
