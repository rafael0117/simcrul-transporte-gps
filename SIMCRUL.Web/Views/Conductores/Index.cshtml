@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Mantenimiento de Conductores";
}

<div class="page-shell">
    <div class="page-header-actions">
        <div>
            <h1 style="font-size: 2rem; font-weight: 800; background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                <i class="fa-solid fa-id-card"></i> Mantenimiento de Conductores
            </h1>
            <p style="color: var(--text-secondary); font-size: 0.95rem; margin-top: 0.25rem;">
                Gestione los conductores asignados a la operacion de la flota.
            </p>
        </div>
        <button onclick="openModal()" class="btn-primary">
            <i class="fa-solid fa-plus"></i> Agregar Conductor
        </button>
    </div>

    <div class="glass-card page-filter-bar">
        <div class="page-filter-main">
            <input type="text" id="search-input" onkeyup="filterTable()" class="custom-input" placeholder="Buscar por nombres, apellidos o DNI..." style="padding-left: 2.5rem;" />
            <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
        </div>
        <div class="page-filter-toggle">
            <label class="form-label" style="margin-bottom: 0; white-space: nowrap;">Mostrar inactivos</label>
            <input type="checkbox" id="show-deleted" onchange="fetchDrivers()" style="width: 18px; height: 18px; cursor: pointer; accent-color: var(--primary);" />
        </div>
    </div>

    <div class="glass-card responsive-table-card">
        <table id="drivers-table">
            <thead>
                <tr style="border-bottom: 2px solid var(--border-color); color: var(--text-secondary); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">
                    <th style="padding: 1rem;">Nombre Completo</th>
                    <th style="padding: 1rem;">DNI</th>
                    <th style="padding: 1rem;">Usuario Login</th>
                    <th style="padding: 1rem;">Licencia</th>
                    <th style="padding: 1rem; text-align: center;">Categoria</th>
                    <th style="padding: 1rem; text-align: center;">Vence Licencia</th>
                    <th style="padding: 1rem; text-align: center;">Telefono</th>
                    <th style="padding: 1rem; text-align: center;">Estado</th>
                    <th style="padding: 1rem; text-align: right;">Acciones</th>
                </tr>
            </thead>
            <tbody id="drivers-list">
                <tr>
                    <td colspan="9" style="text-align: center; padding: 3rem; color: var(--text-muted);">
                        <i class="fa-solid fa-spinner fa-spin" style="font-size: 1.5rem; margin-bottom: 0.5rem; display: block;"></i> Cargando conductores...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div id="driver-modal" class="modal-overlay">
    <div class="glass-card modal-card">
        <div class="modal-header">
            <h3 id="modal-title" style="font-size: 1.3rem; font-weight: 700; color: white;">
                <i class="fa-solid fa-id-card"></i> Agregar Conductor
            </h3>
            <button onclick="closeModal()" style="background: none; border: none; color: var(--text-secondary); cursor: pointer; font-size: 1.25rem;">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <form id="driver-form" onsubmit="saveDriver(event)" class="modal-form">
            <input type="hidden" id="driver-id" value="0" />

            <div class="form-grid-2">
                <div>
                    <label class="form-label">Nombres *</label>
                    <input type="text" id="nombres" class="custom-input" placeholder="Ej: Carlos Daniel" required />
                </div>
                <div>
                    <label class="form-label">Apellidos *</label>
                    <input type="text" id="apellidos" class="custom-input" placeholder="Ej: Mendoza Flores" required />
                </div>
            </div>

            <div class="form-grid-2">
                <div>
                    <label class="form-label">DNI *</label>
                    <input type="text" id="dni" class="custom-input" max-length="8" placeholder="Ej: 72849284" required />
                </div>
                <div>
                    <label class="form-label">Telefono</label>
                    <input type="text" id="telefono" class="custom-input" placeholder="Ej: 988776655" />
                </div>
            </div>

            <div>
                <label class="form-label">Usuario conductor vinculado</label>
                <select id="id-usuario" class="custom-input">
                    <option value="">-- Sin usuario vinculado --</option>
                </select>
                <div style="margin-top: 0.5rem; color: var(--text-muted); font-size: 0.82rem;">
                    Solo los usuarios con rol <strong>Conductor</strong> pueden asociarse a este registro.
                </div>
            </div>

            <div class="form-grid-split">
                <div>
                    <label class="form-label">Numero de Licencia *</label>
                    <input type="text" id="num-licencia" class="custom-input" placeholder="Ej: Q72849284" required />
                </div>
                <div>
                    <label class="form-label">Categoria Licencia *</label>
                    <input type="text" id="cat-licencia" class="custom-input" placeholder="Ej: A-IIIA" required />
                </div>
            </div>

            <div>
                <label class="form-label">Fecha Vencimiento Licencia *</label>
                <input type="date" id="vence-licencia" class="custom-input" required />
            </div>

            <div id="estado-container" style="display: none; align-items: center; gap: 0.5rem;">
                <input type="checkbox" id="estado" style="width: 18px; height: 18px; cursor: pointer; accent-color: var(--primary);" checked />
                <label class="form-label" style="margin-bottom: 0; cursor: pointer;" for="estado">Conductor Activo</label>
            </div>

            <div class="modal-actions">
                <button type="button" onclick="closeModal()" class="custom-input" style="width: auto; padding: 0.6rem 1.5rem; background: rgba(255,255,255,0.05); color: white; cursor: pointer; border-radius: 8px;">
                    Cancelar
                </button>
                <button type="submit" class="btn-primary" style="border-radius: 8px; padding: 0.6rem 2rem;">
                    Guardar
                </button>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <style>
        #drivers-table tbody tr {
            border-bottom: 1px solid var(--border-color);
            transition: background 0.2s;
        }

        #drivers-table tbody tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        .status-badge {
            padding: 0.25rem 0.6rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
        }

        .status-active {
            background: rgba(16, 185, 129, 0.15);
            color: var(--success);
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        .status-inactive {
            background: rgba(239, 68, 68, 0.15);
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .btn-action {
            background: none;
            border: none;
            cursor: pointer;
            padding: 0.25rem 0.5rem;
            border-radius: 6px;
            font-size: 0.9rem;
            transition: all 0.2s;
        }

        .btn-edit {
            color: var(--primary);
        }

        .btn-edit:hover {
            background: rgba(6, 182, 212, 0.1);
        }

        .btn-status {
            color: var(--warning);
        }

        .btn-status:hover {
            background: rgba(245, 158, 11, 0.1);
        }
    </style>
}

@section Scripts {
    <script>
        const apiBaseUrl = '@(Configuration["ApiSettings:BrowserBaseUrl"] ?? Configuration["ApiSettings:BaseUrl"])';
        const token = '@Context.Session.GetString("Token")';

        let allDrivers = [];
        let driverUsers = [];

        async function fetchDrivers() {
            const showDeleted = document.getElementById('show-deleted').checked;
            const tbody = document.getElementById('drivers-list');

            try {
                const res = await fetch(`${apiBaseUrl}conductores?includeDeleted=${showDeleted}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (res.ok) {
                    allDrivers = await res.json();
                    renderTable(allDrivers);
                } else {
                    tbody.innerHTML = `<tr><td colspan="9" style="text-align:center; padding:2rem; color:var(--danger);">Error al cargar conductores (${res.status}).</td></tr>`;
                }
            } catch (err) {
                console.error(err);
                tbody.innerHTML = `<tr><td colspan="9" style="text-align:center; padding:2rem; color:var(--danger);">Falla de conexion con la API.</td></tr>`;
            }
        }

        async function fetchDriverUsers() {
            try {
                const res = await fetch(`${apiBaseUrl}conductores/driver-users`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (!res.ok) {
                    throw new Error(`Error ${res.status}`);
                }

                driverUsers = await res.json();
                renderDriverUsers();
            } catch (err) {
                console.error(err);
            }
        }

        function renderDriverUsers(currentDriverId = null) {
            const select = document.getElementById('id-usuario');
            select.innerHTML = '<option value="">-- Sin usuario vinculado --</option>';

            driverUsers.forEach(user => {
                const isTakenByAnotherDriver = user.asignado && user.idConductorAsignado !== currentDriverId;
                const selectedLabel = isTakenByAnotherDriver
                    ? `${user.username} - ${user.nombreCompleto} (asignado a conductor #${user.idConductorAsignado})`
                    : `${user.username} - ${user.nombreCompleto}`;

                select.innerHTML += `<option value="${user.idUsuario}" ${isTakenByAnotherDriver ? 'disabled' : ''}>${selectedLabel}</option>`;
            });
        }

        function renderTable(list) {
            const tbody = document.getElementById('drivers-list');
            if (list.length === 0) {
                tbody.innerHTML = `<tr><td colspan="9" style="text-align:center; padding:3rem; color:var(--text-muted);">No se encontraron conductores.</td></tr>`;
                return;
            }

            tbody.innerHTML = '';
            list.forEach(driver => {
                const venceDate = new Date(driver.fechaVencimientoLicencia).toLocaleDateString('es-PE');
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td style="padding:1rem; font-weight:700;">${driver.nombres} ${driver.apellidos}</td>
                    <td style="padding:1rem;">${driver.dni}</td>
                    <td style="padding:1rem;">
                        ${driver.usernameUsuario
                            ? `<div style="font-weight:700;">${driver.usernameUsuario}</div><div style="font-size:0.8rem; color:var(--text-secondary);">${driver.nombreUsuario || ''}</div>`
                            : '<span style="color:var(--warning);">Sin vincular</span>'}
                    </td>
                    <td style="padding:1rem; font-family:monospace; color:var(--text-secondary);">${driver.numeroLicencia}</td>
                    <td style="padding:1rem; text-align:center;"><span style="font-size:0.85rem; background:rgba(255,255,255,0.05); padding:2px 8px; border-radius:4px;">${driver.categoriaLicencia}</span></td>
                    <td style="padding:1rem; text-align:center;">${venceDate}</td>
                    <td style="padding:1rem; text-align:center;">${driver.telefono || '-'}</td>
                    <td style="padding:1rem; text-align:center;">
                        <span class="status-badge ${driver.estado ? 'status-active' : 'status-inactive'}">
                            ${driver.estado ? 'Activo' : 'Inactivo'}
                        </span>
                    </td>
                    <td style="padding:1rem; text-align:right;">
                        <button onclick="editDriver(${driver.idConductor})" class="btn-action btn-edit" title="Editar"><i class="fa-solid fa-pen-to-square"></i></button>
                        <button onclick="toggleDriverStatus(${driver.idConductor})" class="btn-action btn-status" title="${driver.estado ? 'Desactivar' : 'Activar'}"><i class="fa-solid ${driver.estado ? 'fa-toggle-off' : 'fa-toggle-on'}"></i></button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function filterTable() {
            const query = document.getElementById('search-input').value.toLowerCase().trim();
            if (!query) {
                renderTable(allDrivers);
                return;
            }

            const filtered = allDrivers.filter(driver =>
                driver.nombres.toLowerCase().includes(query) ||
                driver.apellidos.toLowerCase().includes(query) ||
                driver.dni.includes(query) ||
                driver.numeroLicencia.toLowerCase().includes(query) ||
                (driver.usernameUsuario || '').toLowerCase().includes(query)
            );

            renderTable(filtered);
        }

        function openModal(isEdit = false) {
            const modal = document.getElementById('driver-modal');
            modal.classList.add('active');
            document.getElementById('estado-container').style.display = isEdit ? 'flex' : 'none';

            if (!isEdit) {
                document.getElementById('modal-title').innerHTML = '<i class="fa-solid fa-id-card"></i> Agregar Conductor';
                document.getElementById('driver-form').reset();
                document.getElementById('driver-id').value = '0';
                document.getElementById('estado').checked = true;
                renderDriverUsers();
            }
        }

        function closeModal() {
            document.getElementById('driver-modal').classList.remove('active');
        }

        function editDriver(id) {
            const driver = allDrivers.find(item => item.idConductor === id);
            if (!driver) {
                return;
            }

            document.getElementById('modal-title').innerHTML = '<i class="fa-solid fa-id-card"></i> Editar Conductor';
            document.getElementById('driver-id').value = driver.idConductor;
            document.getElementById('nombres').value = driver.nombres;
            document.getElementById('apellidos').value = driver.apellidos;
            document.getElementById('dni').value = driver.dni;
            document.getElementById('telefono').value = driver.telefono || '';
            renderDriverUsers(driver.idConductor);
            document.getElementById('id-usuario').value = driver.idUsuario || '';
            document.getElementById('num-licencia').value = driver.numeroLicencia;
            document.getElementById('cat-licencia').value = driver.categoriaLicencia;
            document.getElementById('vence-licencia').value = new Date(driver.fechaVencimientoLicencia).toISOString().split('T')[0];
            document.getElementById('estado').checked = driver.estado;

            openModal(true);
        }

        async function saveDriver(e) {
            e.preventDefault();
            const id = parseInt(document.getElementById('driver-id').value);

            const payload = {
                idConductor: id,
                idUsuario: document.getElementById('id-usuario').value ? parseInt(document.getElementById('id-usuario').value, 10) : null,
                nombres: document.getElementById('nombres').value,
                apellidos: document.getElementById('apellidos').value,
                dni: document.getElementById('dni').value,
                telefono: document.getElementById('telefono').value || null,
                numeroLicencia: document.getElementById('num-licencia').value,
                categoriaLicencia: document.getElementById('cat-licencia').value,
                fechaVencimientoLicencia: new Date(document.getElementById('vence-licencia').value).toISOString(),
                estado: id === 0 ? true : document.getElementById('estado').checked
            };

            const method = id === 0 ? 'POST' : 'PUT';
            const url = id === 0 ? `${apiBaseUrl}conductores` : `${apiBaseUrl}conductores/${id}`;

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                if (res.ok) {
                    closeModal();
                    await Promise.all([fetchDrivers(), fetchDriverUsers()]);
                } else {
                    const err = await res.json();
                    alert(`Error al guardar: ${err.message || 'Intente nuevamente'}`);
                }
            } catch (err) {
                alert('Falla de conexion.');
            }
        }

        async function toggleDriverStatus(id) {
            const driver = allDrivers.find(item => item.idConductor === id);
            if (!driver) {
                return;
            }

            const action = driver.estado ? 'desactivar' : 'activar';
            if (!confirm(`Estas seguro que desea ${action} este conductor?`)) {
                return;
            }

            try {
                const res = await fetch(`${apiBaseUrl}conductores/${id}`, {
                    method: 'PUT',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        ...driver,
                        estado: !driver.estado
                    })
                });

                if (res.ok) {
                    await Promise.all([fetchDrivers(), fetchDriverUsers()]);
                } else {
                    const err = await res.json();
                    alert(`Error al actualizar el estado: ${err.message || 'Intente nuevamente'}`);
                }
            } catch (err) {
                alert('Falla de conexion.');
            }
        }

        Promise.all([fetchDrivers(), fetchDriverUsers()]);
    </script>
}

