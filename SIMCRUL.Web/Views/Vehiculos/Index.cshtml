@model List<SIMCRUL.Common.DTOs.Vehicles.VehicleManagementDto>
@{
    ViewData["Title"] = "Vehiculos";
}

<section class="page-actions">
    <a asp-action="Crear" class="btn btn-primary">Nuevo vehiculo</a>
</section>

<section class="table-card">
    <table>
        <thead>
            <tr>
                <th>Codigo</th>
                <th>Placa</th>
                <th>Tipo</th>
                <th>Estado operativo</th>
                <th>Kilometraje</th>
                <th>Ultima inspeccion</th>
                <th>Ultimo mantenimiento</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CodigoInterno</td>
                <td>@item.Placa</td>
                <td>@item.TipoVehiculo</td>
                <td><span class="chip @(item.EstadoOperativo == "FUERA_DE_SERVICIO" ? "danger" : item.EstadoOperativo == "EN_MANTENIMIENTO" ? "warn" : "")">@item.EstadoOperativo</span></td>
                <td>@item.KilometrajeActual.ToString("N0") km</td>
                <td>@(item.FechaUltimaInspeccion?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                <td>@(item.FechaUltimoMantenimiento?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                <td>
                    <div class="inline-actions">
                        <a asp-action="Editar" asp-route-id="@item.IdVehiculo" class="btn btn-light">Editar</a>
                        <form asp-action="Eliminar" method="post">
                            <input type="hidden" name="id" value="@item.IdVehiculo" />
                            <button type="submit" class="btn btn-secondary">Desactivar</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>
